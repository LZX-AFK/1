}

export function onDeviceFound(callback: NativeDeviceFoundCallback): () => void {
  deviceFoundCallbacks.add(callback)
  return () => {
    deviceFoundCallbacks.delete(callback)
  }
}

export function onConnectionChanged(callback: NativeConnectionCallback): () => void {
  connectionCallbacks.add(callback)
  return () => {
    connectionCallbacks.delete(callback)
  }
}

export function onDpReport(callback: NativeDpCallback): () => void {
  dpCallbacks.add(callback)
  return () => {
    dpCallbacks.delete(callback)
  }
}

export function onShortcutKey(callback: NativeShortcutKeyCallback): () => void {
  shortcutKeyCallbacks.add(callback)
  return () => {
    shortcutKeyCallbacks.delete(callback)
  }
}

export function onRecordingProgress(callback: NativeProgressCallback): () => void {
  recordingProgressCallbacks.add(callback)
  return () => {
    recordingProgressCallbacks.delete(callback)
  }
}

export function onDecodeProgress(callback: NativeProgressCallback): () => void {
  decodeProgressCallbacks.add(callback)
  return () => {
    decodeProgressCallbacks.delete(callback)
  }
}

export function onError(callback: NativeErrorCallback): () => void {
  errorCallbacks.add(callback)
  return () => {
    errorCallbacks.delete(callback)
  }
}

export function getDiagnostics(): any {
  return {
    version: SDK_VERSION,
    platform: 'ios',
    scanning,
    connected: connectedDeviceId != null,
    connecting,
    generation: sessionGeneration,
    channels: channelReadySnapshot(),
    control: {
      active: activeControlTransaction == null
        ? null
        : {
            kind: activeControlTransaction.kind,
            dpId: activeControlTransaction.dpId,
            sendSn: activeControlTransaction.sendSn,
            attempts: activeControlTransaction.attempts,
            generation: activeControlTransaction.generation
          },
      queueDepth: controlTransactionQueue.length,
      snapshotSize: dpSnapshot.size
    },
    recording: {
      active: recordingSession == null
        ? null
        : recordingSessionSummary(recordingSession),
      pending: pendingRecordingCommand == null
        ? null
        : {
            kind: pendingRecordingCommand.kind,
            generation: pendingRecordingCommand.generation
          }
    },
    events: diagnostics.slice()
  }
}

export function clearDiagnostics(): void {
  diagnostics.splice(0, diagnostics.length)
}
