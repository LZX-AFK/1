}

class DpEvent {
  dpId: number
  id: number
  name: string
  typeCode: number
  rawValue: Array<number>
  raw: Array<number>
  value: any | null
  timestamp: string
  source: string

  constructor(dp: DataPoint, name: string, value: any | null, source: string = '') {
    this.dpId = dp.id
    this.id = dp.id
    this.name = name
    this.typeCode = dp.typeCode
    this.rawValue = dp.rawValue
    this.raw = dp.rawValue
    this.value = value
    this.timestamp = nowIso()
    this.source = source
  }
}

class ControlTransaction {
  kind: string
  dpId: number
  frame: Array<number>
