function asNativeError(error: any): OleapBleNativeError | null {
  if (error instanceof OleapBleNativeError) {
    return error as OleapBleNativeError
  }
  return null
}

function optionObject(options: any | null): UTSJSONObject | null {
  if (options == null) {
    return null
  }
  return new UTSJSONObject(options)
}

function optionValue(options: any | null, key: string): any | null {
  const object = optionObject(options)
  if (object == null) {
    return null
  }
  return object.getAny(key)
}

function optionString(options: any | null, key: string, fallback: string | null = null): string | null {
  const object = optionObject(options)
  if (object == null) {
    return fallback
  }
  const direct = object.getString(key)
  if (direct != null) {
    return direct
  }
  const value = object.getAny(key)
  return value == null ? fallback : `${value}`
}

function optionNumber(options: any | null, key: string, fallback: number): number {
  const object = optionObject(options)
  if (object == null) {
    return fallback
  }
  const direct = object.getNumber(key)
  if (direct != null) {
    return direct
  }
  const value = object.getAny(key)
  if (value == null) {
    return fallback
  }
  const parsed = parseFloat(`${value}`)
  return isNaN(parsed) ? fallback : parsed
}

function optionInt(options: any | null, key: string, fallback: Int): Int {
  const value = optionNumber(options, key, fallback)
  return value.toInt()
}

function optionPositiveNumber(options: any | null, key: string, fallback: number): number {
  const requestedTimeoutMs = optionNumber(options, key, fallback)
  return requestedTimeoutMs > 0 ? requestedTimeoutMs : fallback
}

function optionBoolean(options: any | null, key: string, fallback: boolean = false): boolean {
  const object = optionObject(options)
  if (object == null) {
    return fallback
  }
  const direct = object.getBoolean(key)
  if (direct != null) {
    return direct
  }
  const value = object.getAny(key)
  if (value == null) {
    return fallback
  }
  return `${value}` == 'true' || `${value}` == '1'
}

function nonNullAny(value: any | null): any {
  return value == null ? {} : value
}

