  desc: number
  messageType: number
  payload: Array<number>
  crc32: number | null
  error: boolean

  constructor(desc: number, messageType: number, payload: Array<number>, crc32: number | null, error: boolean) {
    this.desc = desc
    this.messageType = messageType
    this.payload = payload
    this.crc32 = crc32
    this.error = error
  }
}

