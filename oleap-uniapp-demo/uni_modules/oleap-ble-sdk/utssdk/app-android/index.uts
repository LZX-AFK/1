  reject: (error: any | null) => void

  constructor(
    kind: string,
    dpId: number,
    frame: Array<number>,
    sendSn: number,
    generation: number,
    resolve: (value: DpEvent | null) => void,
    reject: (error: any | null) => void
  ) {
    this.kind = kind
    this.dpId = dpId
    this.frame = frame
    this.sendSn = sendSn
    this.generation = generation
    this.resolve = resolve
    this.reject = reject
  }
}

