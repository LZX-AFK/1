}

export function getDiagnostics(): any {
  const activeControl = activeControlTransaction
  const activeRecording = recordingSession
  const pendingRecording = pendingRecordingCommand
  const activeFlash = flashSession
  const pendingFlash = pendingFlashCommand
  return {
    version: SDK_VERSION,
    platform: 'android',
    scanning,
    connected: connectedDeviceId != null,
    connecting,
    generation: sessionGeneration,
    channels: channelReadySnapshot(),
    control: {
      active: activeControl == null
        ? null
        : {
            kind: activeControl.kind,
            dpId: activeControl.dpId,
            sendSn: activeControl.sendSn,
            attempts: activeControl.attempts,
            generation: activeControl.generation
          },
      queueDepth: controlTransactionQueue.length,
      snapshotSize: dpSnapshot.size
    },
    recording: {
      active: activeRecording == null
        ? null
        : recordingSessionSummary(activeRecording),
      pending: pendingRecording == null
        ? null
        : {
            kind: pendingRecording.kind,
            generation: pendingRecording.generation
          }
    },
    flash: {
      active: activeFlash == null
        ? null
        : recordingSessionSummary(activeFlash.session),
      pending: pendingFlash == null
        ? null
        : {
            kind: pendingFlash.kind,
            generation: pendingFlash.generation
          },
      headFileId: flashHeadFileId,
      cachedFileCount: flashFileListSnapshot.length
    },
    events: diagnostics.slice()
  }
}

export function clearDiagnostics(): void {
  diagnostics.splice(0, diagnostics.length)
}

// Returns the first bonded classic BT device that is currently connected and active as an audio
// output, and whose MAC starts with "01:EA" (the oleap OUI prefix). Used for auto-connect on
// Android where the classic BT MAC equals the BLE GATT address.
export function getActiveBtDevice(): Promise<any | null> {
  const adapter = getBluetoothAdapter()
  if (adapter == null) {
    return Promise.resolve(null)
  }
  try {
    const bonded = adapter.getBondedDevices()
    if (bonded == null) {
      return Promise.resolve(null)
    }
    for (let device in bonded) {
      const address = deviceAddressOf(device)
      if (!address.toUpperCase().startsWith("01:EA")) {
        continue
      }
      let isConnected = false
      try {
        isConnected = UTSAndroid.getJavaClass(BluetoothDevice).getMethod("isConnected").invoke(device) as boolean
      } catch (_e) {}
      if (!isConnected) {
        continue
      }
      const name = deviceNameOf(device)
      pushDiagnostic('active_bt_device_found', { deviceId: address, name })
      return Promise.resolve({ deviceId: address, name: name.length > 0 ? name : 'Oleap 设备' })
    }
  } catch (error) {
    pushDiagnostic('active_bt_device_error', { error: `${error}` })
  }
  return Promise.resolve(null)
}
