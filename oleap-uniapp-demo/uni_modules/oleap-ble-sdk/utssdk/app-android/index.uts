const discoveredDeviceIds = new Set<string>()
const dpSnapshot = new Map<number, DpEvent>()

class OleapClassicDiscoveryReceiver extends BroadcastReceiver {
  constructor() {
    super()
  }

  @UTSJS.keepAlive
  override onReceive(_context: Context, intent: Intent): void {
    const action = intent.getAction()
    if (action == null) {
      return
    }
    if (action == BluetoothDevice.ACTION_FOUND) {
      const rawDevice = intent.getParcelableExtra<BluetoothDevice>(BluetoothDevice.EXTRA_DEVICE)
      if (rawDevice == null || !(rawDevice instanceof BluetoothDevice)) {
        return
      }
      const device = rawDevice as BluetoothDevice
      const name = deviceNameOf(device)
      if (!isOleapDeviceName(name)) {
        return
      }
      emitDeviceFound(new OleapDeviceInfo(
        deviceAddressOf(device),
        name,
        0,
        ''
      ))
      return
    }
    if (action == BluetoothAdapter.ACTION_DISCOVERY_FINISHED) {
      pushDiagnostic('classic_discovery_finished', {
        discovered: discoveredDeviceIds.size
      })
    }
  }
}

function nowIso(): string {
  return new Date().toISOString()
}

function pushDiagnostic(event: string, details: any | null = null): void {
  diagnostics.push({
    timestamp: nowIso(),
    event,
    details
  })
  if (diagnostics.length > DIAGNOSTIC_LIMIT) {
    diagnostics.splice(0, diagnostics.length - DIAGNOSTIC_LIMIT)
  }
}

function makeError(code: string, message: string, area: OleapBleErrorArea, recoverable: boolean = true, details: any | null = null): OleapBleNativeError {
  return new OleapBleNativeError(code, message, area, recoverable, details)
}

function emitError(error: OleapBleNativeError): void {
  const event = {
    code: error.code,
    message: error.message,
    area: error.area,
    recoverable: error.recoverable,
    details: error.details
  }
  pushDiagnostic('error', event)
  errorCallbacks.forEach((callback) => {
    callback(event)
  })
}

function rejectWith<T>(error: OleapBleNativeError): Promise<T> {
  emitError(error)
  return new Promise<T>((_resolve, reject) => {
    reject(error)
  })
}

function resolvePendingConnect(device: any): void {
  if (connectTimeoutId != null) {
    clearTimeout(connectTimeoutId!)
    connectTimeoutId = null
  }
  connecting = false
  const resolve = pendingConnectResolve
  pendingConnectResolve = null
  pendingConnectReject = null
  if (resolve != null) {
    resolve(device)
  }
}

function rejectPendingConnect(error: OleapBleNativeError): void {
  if (connectTimeoutId != null) {
    clearTimeout(connectTimeoutId!)
    connectTimeoutId = null
  }
  connecting = false
  const reject = pendingConnectReject
  pendingConnectResolve = null
  pendingConnectReject = null
  emitError(error)
  if (reject != null) {
    reject(error)
  }
}

function clearWriteTimeout(): void {
  if (writeTimeoutId != null) {
    clearTimeout(writeTimeoutId!)
    writeTimeoutId = null
  }
}

function clearMtuRequestTimeout(): void {
  if (mtuRequestTimeoutId != null) {
    clearTimeout(mtuRequestTimeoutId!)
    mtuRequestTimeoutId = null
  }
}

function clearServiceDiscoveryRetryTimeout(): void {
  if (serviceDiscoveryRetryTimeoutId != null) {
    clearTimeout(serviceDiscoveryRetryTimeoutId!)
    serviceDiscoveryRetryTimeoutId = null
  }
}

function rejectQueuedWrites(error: OleapBleNativeError): void {
  clearWriteTimeout()
  const active = activeWriteRequest
  activeWriteRequest = null
  if (active != null && active.reject != null) {
    active.reject(error)
  }
  while (writeQueue.length > 0) {
    const request = writeQueue.shift()
    if (request != null && request.reject != null) {
      request.reject(error)
    }
  }
}

function clearControlTimeout(): void {
  if (controlTimeoutId != null) {
    clearTimeout(controlTimeoutId!)
    controlTimeoutId = null
  }
}

function clearRecordingCommandTimeout(): void {
  if (recordingCommandTimeoutId != null) {
    clearTimeout(recordingCommandTimeoutId!)
    recordingCommandTimeoutId = null
  }
}

function clearFlashCommandTimeout(): void {
  if (flashCommandTimeoutId != null) {
    clearTimeout(flashCommandTimeoutId!)
    flashCommandTimeoutId = null
  }
}

function clearFlashDownloadTimeout(): void {
  if (flashDownloadTimeoutId != null) {
    clearTimeout(flashDownloadTimeoutId!)
    flashDownloadTimeoutId = null
  }
}

function rejectControlRequest(request: ControlTransaction | null, error: OleapBleNativeError, emit: boolean = true): void {
  if (request == null || request.completed == true) {
    return
  }
  request.completed = true
  if (emit) {
    emitError(error)
  }
  if (request.reject != null) {
    request.reject(error)
  }
}

function resetControlProtocol(reason: string): void {
  clearControlTimeout()
  const error = makeError(
    'control_disconnected',
    reason,
    'control',
    true,
    { generation: sessionGeneration }
  )
  const active = activeControlTransaction
  activeControlTransaction = null
  rejectControlRequest(active, error, false)
  while (controlTransactionQueue.length > 0) {
    rejectControlRequest(controlTransactionQueue.shift(), error, false)
  }
  controlSendSn = 0
  controlAppDpSn = 0
  dpSnapshot.clear()
}

function rejectRecordingCommand(request: RecordingCommandRequest | null, error: OleapBleNativeError, emit: boolean = true): void {
  if (request == null || request.completed == true) {
    return
  }
  request.completed = true
  if (pendingRecordingCommand == request) {
    pendingRecordingCommand = null
  }
  clearRecordingCommandTimeout()
  if (emit) {
    emitError(error)
  }
  if (request.reject != null) {
    request.reject(error)
  }
}

function resetRecordingProtocol(reason: string): void {
  clearRecordingCommandTimeout()
  const error = makeError(
    'recording_disconnected',
    reason,
    'recording',
    true,
    { generation: sessionGeneration }
  )
  const pending = pendingRecordingCommand
  pendingRecordingCommand = null
  rejectRecordingCommand(pending, error, false)
  const active = recordingSession
  if (active != null) {
    closeRecordingSessionStreams(active)
    pushDiagnostic('recording_session_abandoned', {
      sessionId: active.sessionId,
      frameCount: active.frameCount,
      reason
    })
  }
  recordingSession = null
}

function rejectFlashCommand(request: FlashCommandRequest | null, error: OleapBleNativeError, emit: boolean = true): void {
  if (request == null || request.completed == true) {
    return
  }
  request.completed = true
  if (pendingFlashCommand == request) {
    pendingFlashCommand = null
  }
  clearFlashCommandTimeout()
  if (emit) {
    emitError(error)
  }
  if (request.reject != null) {
    request.reject(error)
  }
}

function rejectFlashSession(active: FlashDownloadSession | null, error: OleapBleNativeError, emit: boolean = true): void {
  if (active == null || active.completed == true) {
    return
  }
  active.completed = true
  if (flashSession == active) {
    flashSession = null
  }
  clearFlashDownloadTimeout()
  closeRecordingSessionStreams(active.session)
  if (emit) {
    emitError(error)
  }
  if (active.reject != null) {
    active.reject(error)
  }
}

function resetFlashProtocol(reason: string): void {
  clearFlashCommandTimeout()
  clearFlashDownloadTimeout()
  const error = makeError(
    'flash_disconnected',
    reason,
    'flash',
    true,
    { generation: sessionGeneration }
  )
  const pending = pendingFlashCommand
  pendingFlashCommand = null
  rejectFlashCommand(pending, error, false)
  const active = flashSession
  flashSession = null
  rejectFlashSession(active, error, false)
  flashHeadFileId = null
  flashFileListSnapshot.splice(0, flashFileListSnapshot.length)
}

function getContext(): Context | null {
  const context = UTSAndroid.getAppContext()
  if (context == null) {
    return null
  }
  return context as Context
}

function getBluetoothAdapter(): BluetoothAdapter | null {
  const context = getContext()
  if (context == null) {
    return null
  }
  const service = context.getSystemService(Context.BLUETOOTH_SERVICE)
  if (service == null) {
    return null
  }
  const manager = service as BluetoothManager
  return manager.getAdapter()
}

function appTargetSdkVersion(): Int {
  const context = getContext()
  if (context == null) {
    return 0
  }
  return context.getApplicationInfo().targetSdkVersion
}

function usesAndroid12BluetoothPermissions(): boolean {
  return Build.VERSION.SDK_INT >= 31
}

function isAndroid12TargetTooLow(): boolean {
  return Build.VERSION.SDK_INT >= 31 && appTargetSdkVersion() < 31
}

function permissionModeOf(modernGranted: boolean = false): string {
  if (Build.VERSION.SDK_INT >= 31) {
    if (modernGranted) {
      return 'android12-bluetooth'
    }
    return isAndroid12TargetTooLow() ? 'android12-target-too-low' : 'android12-bluetooth'
  }
  return 'legacy-location'
}

function requiredPermissions(): Array<string> {
  if (usesAndroid12BluetoothPermissions()) {
    return [
      'android.permission.BLUETOOTH_SCAN',
      'android.permission.BLUETOOTH_CONNECT'
    ]
  }
  return [
    'android.permission.ACCESS_FINE_LOCATION'
  ]
}

function hasLegacyLocationPermission(): boolean {
  const activity = UTSAndroid.getUniActivity()
  if (activity == null) {
    return false
  }
  return UTSAndroid.checkSystemPermissionGranted(activity, [
    'android.permission.ACCESS_FINE_LOCATION'
  ])
}

function hasModernBluetoothPermissions(): boolean {
  if (Build.VERSION.SDK_INT < 31) {
    return false
  }
  const activity = UTSAndroid.getUniActivity()
  if (activity == null) {
    return false
  }
  return UTSAndroid.checkSystemPermissionGranted(activity, [
    'android.permission.BLUETOOTH_SCAN',
    'android.permission.BLUETOOTH_CONNECT'
  ])
}

function hasRequiredPermissions(): boolean {
  if (Build.VERSION.SDK_INT >= 31) {
    return hasModernBluetoothPermissions()
  }
  return hasLegacyLocationPermission()
}

function permissionResult(): any {
  const modernGranted = hasModernBluetoothPermissions()
  const legacyGranted = hasLegacyLocationPermission()
  const granted = modernGranted || legacyGranted
  return {
    bluetooth: granted,
    location: legacyGranted,
    permissionGranted: granted,
    androidSdk: Build.VERSION.SDK_INT,
    targetSdk: appTargetSdkVersion(),
    permissionMode: permissionModeOf(modernGranted),
    modernPermissionsGranted: modernGranted,
    legacyLocationGranted: legacyGranted,
    targetAwarePermissionMode: permissionModeOf(modernGranted)
  }
}

function ensureInitialized(): OleapBleNativeError | null {
  if (initialized) {
    return null
  }
  return makeError('sdk_not_initialized', '请先调用 OleapBle.init()', 'sdk', true)
}

function deviceNameOf(device: BluetoothDevice): string {
  try {
    const name = device.getName()
    if (name != null && name.length > 0) {
      return name
    }
  } catch (_error) {}
  return ''
}

function scanRecordNameOf(result: ScanResult): string {
  try {
    const record = result.getScanRecord()
    if (record != null) {
      const name = record.getDeviceName()
      if (name != null && name.length > 0) {
        return name
      }
    }
  } catch (_error) {}
  return ''
}

function resultNameOf(result: ScanResult): string {
  const device = result.getDevice()
  if (device != null) {
    const name = deviceNameOf(device)
    if (name.length > 0) {
      return name
    }
  }
  return scanRecordNameOf(result)
}

function normalizedDeviceName(name: string): string {
  return name.trim().toLowerCase()
}

function isOleapDeviceName(name: string): boolean {
  const normalized = normalizedDeviceName(name)
  return normalized.length > 0 && normalized.startsWith(OLEAP_NAME_PREFIX)
}

function deviceAddressOf(device: BluetoothDevice): string {
  try {
    const address = device.getAddress()
    if (address != null && address.length > 0) {
      return address
    }
  } catch (_error) {}
  return ''
}

function isOleapScanResult(result: ScanResult): boolean {
  const device = result.getDevice()
  if (device == null) {
    return false
  }
  const name = resultNameOf(result)
  return isOleapDeviceName(name)
}

function bondedOleapDevices(): Array<OleapDeviceInfo> {
  const adapter = getBluetoothAdapter()
  if (adapter == null) {
    return new Array<OleapDeviceInfo>()
  }
  const devices = new Array<OleapDeviceInfo>()
  try {
    const bonded = adapter.getBondedDevices()
    if (bonded == null) {
      return devices
    }
    for (let device in bonded) {
      const name = deviceNameOf(device)
      if (!isOleapDeviceName(name)) {
        continue
      }
      const deviceId = deviceAddressOf(device)
      if (deviceId.length == 0) {
        pushDiagnostic('bonded_device_missing_address', {
          name,
          androidSdk: Build.VERSION.SDK_INT,
          targetSdk: appTargetSdkVersion(),
          permissionMode: permissionModeOf(hasModernBluetoothPermissions())
        })
        continue
      }
      devices.push(new OleapDeviceInfo(
        deviceId,
        name,
        0,
        ''
      ))
    }
  } catch (error) {
    pushDiagnostic('bonded_devices_failed', {
      error: `${error}`,
      androidSdk: Build.VERSION.SDK_INT,
      targetSdk: appTargetSdkVersion(),
      permissionMode: permissionModeOf(hasModernBluetoothPermissions())
    })
  }
  return devices
}

function toOleapDevice(result: ScanResult): OleapDeviceInfo {
  const device = result.getDevice()
  const id = device == null ? '' : deviceAddressOf(device)
  const name = resultNameOf(result)
  return new OleapDeviceInfo(id, name.length > 0 ? name : 'Oleap Device', result.getRssi(), '')
}

function emitDeviceFound(device: OleapDeviceInfo): void {
  if (device.deviceId == null || device.deviceId.length == 0) {
    return
  }
  if (discoveredDeviceIds.has(device.deviceId)) {
    return
  }
  discoveredDeviceIds.add(device.deviceId)
  pushDiagnostic('device_found', {
    deviceId: device.deviceId,
    name: device.name,
    rssi: device.rssi
  })
  deviceFoundCallbacks.forEach((callback) => {
    callback(device)
  })
}

class OleapScanCallback extends ScanCallback {
  constructor() {
    super()
  }

  @UTSJS.keepAlive
  override onScanResult(callbackType: Int, result: ScanResult): void {
    if (!isOleapScanResult(result)) {
      return
    }
    emitDeviceFound(toOleapDevice(result))
  }

  @UTSJS.keepAlive
  override onBatchScanResults(results: MutableList<ScanResult>): void {
    results.forEach((result: ScanResult) => {
      if (isOleapScanResult(result)) {
        emitDeviceFound(toOleapDevice(result))
      }
    })
  }

  @UTSJS.keepAlive
  override onScanFailed(errorCode: Int): void {
    scanning = false
    scannerCallback = null
    emitError(
      makeError(
        'scan_failed',
        'Android BLE 扫描失败',
        'bluetooth',
        true,
        { errorCode }
      )
    )
  }
}

function unregisterClassicDiscoveryReceiver(): void {
  if (classicDiscoveryReceiver == null) {
    return
  }
  const context = getContext()
  if (context != null) {
    try {
      context.unregisterReceiver(classicDiscoveryReceiver)
    } catch (_error) {}
  }
  classicDiscoveryReceiver = null
}

function startClassicDiscoveryFallback(adapter: BluetoothAdapter, bleError: string): boolean {
  const context = getContext()
  if (context == null) {
    pushDiagnostic('classic_discovery_unavailable', {
      reason: 'context_missing',
      bleError
    })
    return false
  }
  unregisterClassicDiscoveryReceiver()
  const receiver = new OleapClassicDiscoveryReceiver()
  const filter = new IntentFilter()
  filter.addAction(BluetoothDevice.ACTION_FOUND)
  filter.addAction(BluetoothAdapter.ACTION_DISCOVERY_FINISHED)
  try {
    context.registerReceiver(receiver, filter)
    classicDiscoveryReceiver = receiver
    if (adapter.isDiscovering()) {
      adapter.cancelDiscovery()
    }
    const started = adapter.startDiscovery()
    if (!started) {
      unregisterClassicDiscoveryReceiver()
      pushDiagnostic('classic_discovery_rejected', {
        bleError
      })
      return false
    }
    pushDiagnostic('classic_discovery_started', {
      bleError
    })
    return true
  } catch (error) {
    unregisterClassicDiscoveryReceiver()
    pushDiagnostic('classic_discovery_failed', {
      bleError,
      error: `${error}`
    })
    return false
  }
}

function emitKnownDevicesScanFallback(bleError: string): number {
  const devices = bondedOleapDevices()
  devices.forEach((device: OleapDeviceInfo) => {
    emitDeviceFound(device)
  })
  pushDiagnostic('scan_known_devices_fallback', {
    count: devices.length,
    bleError
  })
  return devices.length
}

function stopScanInternal(recordDiagnostic: boolean = true): void {
  if (scanTimeoutId != null) {
    clearTimeout(scanTimeoutId!)
    scanTimeoutId = null
  }
  if (!scanning) {
    return
  }
  const adapter = getBluetoothAdapter()
  const callback = scannerCallback
  scannerCallback = null
  scanning = false
  try {
    if (callback != null) {
      adapter?.getBluetoothLeScanner()?.stopScan(callback)
    }
  } catch (error) {
    emitError(
      makeError(
        'scan_stop_failed',
        '停止 Android BLE 扫描失败',
        'bluetooth',
        true,
        { error: `${error}` }
      )
    )
  }
  try {
    if (adapter?.isDiscovering() == true) {
      adapter.cancelDiscovery()
    }
  } catch (_error) {}
  unregisterClassicDiscoveryReceiver()
  if (recordDiagnostic) {
    pushDiagnostic('scan_stop')
  }
}

function notImplemented<T>(code: string, message: string, area: OleapBleErrorArea): Promise<T> {
  return rejectWith<T>(makeError(code, message, area, true))
}

function clearCharacteristicCache(): void {
  communicationWriteChar = null
  communicationNotifyChar = null
  recordWriteChar = null
  recordNotifyChar = null
  enablingNotifications = false
  notifyEnableGeneration = 0
  activeNotifyDescriptor = null
  pendingNotifyDescriptors.splice(0, pendingNotifyDescriptors.length)
}

function closeGatt(recordDiagnostic: boolean = true): void {
  if (connectTimeoutId != null) {
    clearTimeout(connectTimeoutId!)
    connectTimeoutId = null
  }
  clearMtuRequestTimeout()
  clearServiceDiscoveryRetryTimeout()
  const gatt = connectedGatt
  const hadGatt = gatt != null
  connectedGatt = null
  gattCallback = null
  pendingDeviceId = null
  pendingDeviceName = null
  connectedDeviceId = null
  connectedDeviceName = null
  connecting = false
  currentMtu = DEFAULT_ANDROID_ATT_MTU
  waitingForMtuBeforeDiscovery = false
  serviceDiscoveryAttempt = 0
  clearCharacteristicCache()
  rejectQueuedWrites(
    makeError('ble_disconnected', 'BLE 连接已断开，pending write 已取消', 'connection', true)
  )
  resetControlProtocol('BLE 连接已断开，pending control transaction 已取消')
  resetRecordingProtocol('BLE 连接已断开，pending recording session 已取消')
  resetFlashProtocol('BLE 连接已断开，pending flash session 已取消')
  sessionGeneration += 1
  if (gatt != null) {
    try {
      gatt.disconnect()
    } catch (_error) {}
    try {
      gatt.close()
    } catch (_error) {}
  }
  if (recordDiagnostic) {
    pushDiagnostic('gatt_closed', {
      hadGatt,
      generation: sessionGeneration
    })
  }
}

function sameUuid(actual: UUID | null, expected: string): boolean {
  if (actual == null) {
    return false
  }
  return actual.toString().toLowerCase() == expected.toLowerCase()
}

function findService(gatt: BluetoothGatt, serviceUuid: string): BluetoothGattService | null {
  const services = gatt.getServices()
  for (let i: Int = 0; i < services.size; i++) {
    const service = services.get(i)
    if (sameUuid(service.getUuid(), serviceUuid)) {
      return service
    }
  }
  return null
}

function findCharacteristic(service: BluetoothGattService | null, characteristicUuid: string): BluetoothGattCharacteristic | null {
  if (service == null) {
    return null
  }
  const characteristics = service.getCharacteristics()
  for (let i: Int = 0; i < characteristics.size; i++) {
    const characteristic = characteristics.get(i)
    if (sameUuid(characteristic.getUuid(), characteristicUuid)) {
      return characteristic
    }
  }
  return null
}

function cacheRequiredCharacteristics(gatt: BluetoothGatt): boolean {
  clearCharacteristicCache()
  const communicationService = findService(gatt, COMMUNICATION_SERVICE_UUID)
  const recordService = findService(gatt, RECORD_SERVICE_UUID)
  communicationWriteChar = findCharacteristic(communicationService, COMMUNICATION_WRITE_UUID)
  communicationNotifyChar = findCharacteristic(communicationService, COMMUNICATION_NOTIFY_UUID)
  recordWriteChar = findCharacteristic(recordService, RECORD_WRITE_UUID)
  recordNotifyChar = findCharacteristic(recordService, RECORD_NOTIFY_UUID)
  return communicationWriteChar != null &&
    communicationNotifyChar != null &&
    recordWriteChar != null &&
    recordNotifyChar != null
}

function channelReadySnapshot(): any {
  return {
    communicationReady: communicationWriteChar != null && communicationNotifyChar != null,
    recordReady: recordWriteChar != null && recordNotifyChar != null,
    notificationsReady: !enablingNotifications &&
      communicationNotifyChar != null &&
      recordNotifyChar != null,
    mtu: currentMtu,
    serviceDiscoveryAttempt
  }
}

function emitConnectionChanged(connected: boolean, device: any | null = null): void {
  const event = {
    connected,
    device,
    generation: sessionGeneration,
    channels: channelReadySnapshot()
  }
  connectionCallbacks.forEach((callback) => {
    callback(event)
  })
}

function requestHighConnectionPriority(gatt: BluetoothGatt): void {
  try {
    const requested = gatt.requestConnectionPriority(BluetoothGatt.CONNECTION_PRIORITY_HIGH)
    pushDiagnostic('connection_priority_request', {
      priority: 'high',
      requested,
      generation: sessionGeneration
    })
  } catch (error) {
    pushDiagnostic('connection_priority_request_failed', {
      error: `${error}`,
      generation: sessionGeneration
    })
  }
}

function requestPreferredMtu(gatt: BluetoothGatt): boolean {
  try {
    const requested = gatt.requestMtu(DEFAULT_ANDROID_MTU)
    pushDiagnostic('mtu_request', {
      requestedMtu: DEFAULT_ANDROID_MTU,
      requested,
      generation: sessionGeneration
    })
    return requested
  } catch (error) {
    pushDiagnostic('mtu_request_failed', {
      requestedMtu: DEFAULT_ANDROID_MTU,
      error: `${error}`,
      generation: sessionGeneration
    })
    return false
  }
}

function beginServiceDiscoveryAfterMtu(gatt: BluetoothGatt, reason: string): void {
  if (!waitingForMtuBeforeDiscovery) {
    pushDiagnostic('discover_services_after_mtu_skipped', {
      reason,
      generation: sessionGeneration,
      attempt: serviceDiscoveryAttempt
    })
    return
  }
  waitingForMtuBeforeDiscovery = false
  clearMtuRequestTimeout()
  startServiceDiscovery(gatt, reason)
}

function requestPreferredMtuAndDiscover(gatt: BluetoothGatt): void {
  waitingForMtuBeforeDiscovery = true
  const requested = requestPreferredMtu(gatt)
  if (!requested) {
    beginServiceDiscoveryAfterMtu(gatt, 'mtu_not_requested')
    return
  }
  const generation = sessionGeneration
  clearMtuRequestTimeout()
  mtuRequestTimeoutId = setTimeout(() => {
    if (generation != sessionGeneration || connectedGatt == null || connectedGatt != gatt) {
      pushDiagnostic('mtu_request_timeout_cancelled', {
        scheduledGeneration: generation,
        currentGeneration: sessionGeneration
      })
      return
    }
    pushDiagnostic('mtu_request_timeout', {
      timeoutMs: MTU_REQUEST_TIMEOUT_MS,
      currentMtu,
      generation
    })
    beginServiceDiscoveryAfterMtu(gatt, 'mtu_timeout')
  }, MTU_REQUEST_TIMEOUT_MS)
}

function startServiceDiscovery(gatt: BluetoothGatt, reason: string): void {
  if (connectedGatt == null || connectedGatt != gatt) {
    pushDiagnostic('discover_services_skipped', {
      reason,
      staleGatt: true,
      generation: sessionGeneration
    })
    return
  }
  clearServiceDiscoveryRetryTimeout()
  serviceDiscoveryAttempt = (serviceDiscoveryAttempt + 1).toInt()
  try {
    const discoveryStarted = gatt.discoverServices()
    pushDiagnostic('discover_services_start', {
      reason,
      started: discoveryStarted,
      attempt: serviceDiscoveryAttempt,
      maxAttempts: SERVICE_DISCOVERY_MAX_ATTEMPTS,
      generation: sessionGeneration
    })
    if (!discoveryStarted) {
      retryOrFailServiceDiscovery(
        gatt,
        'discover_services_start_failed',
        '启动服务发现失败',
        {
          reason,
          attempt: serviceDiscoveryAttempt
        }
      )
    }
  } catch (error) {
    retryOrFailServiceDiscovery(
      gatt,
      'discover_services_start_failed',
      '启动服务发现失败',
      {
        reason,
        attempt: serviceDiscoveryAttempt,
        error: `${error}`
      }
    )
  }
}

function retryOrFailServiceDiscovery(gatt: BluetoothGatt, code: string, message: string, details: any | null = null): void {
  if (connectedGatt == null || connectedGatt != gatt) {
    return
  }
  if (serviceDiscoveryAttempt < SERVICE_DISCOVERY_MAX_ATTEMPTS) {
    const generation = sessionGeneration
    pushDiagnostic('discover_services_retry_scheduled', {
      code,
      attempt: serviceDiscoveryAttempt,
      maxAttempts: SERVICE_DISCOVERY_MAX_ATTEMPTS,
      delayMs: SERVICE_DISCOVERY_RETRY_DELAY_MS,
      generation,
      details
    })
    clearServiceDiscoveryRetryTimeout()
    serviceDiscoveryRetryTimeoutId = setTimeout(() => {
      if (generation != sessionGeneration || connectedGatt == null || connectedGatt != gatt) {
        pushDiagnostic('discover_services_retry_cancelled', {
          scheduledGeneration: generation,
          currentGeneration: sessionGeneration
        })
        return
      }
      startServiceDiscovery(gatt, 'retry')
    }, SERVICE_DISCOVERY_RETRY_DELAY_MS)
    return
  }
  closeGatt(true)
  rejectPendingConnect(makeError(code, message, 'connection', true, details))
}

function handleServicesDiscovered(gatt: BluetoothGatt, status: Int): void {
  clearMtuRequestTimeout()
  waitingForMtuBeforeDiscovery = false
  pushDiagnostic('services_discovered', {
    status,
    serviceCount: gatt.getServices().size,
    attempt: serviceDiscoveryAttempt,
    generation: sessionGeneration
  })
  if (status != BluetoothGatt.GATT_SUCCESS) {
    retryOrFailServiceDiscovery(
      gatt,
      'discover_services_failed',
      'Android GATT 服务发现失败',
      {
        status,
        attempt: serviceDiscoveryAttempt
      }
    )
    return
  }

  if (!cacheRequiredCharacteristics(gatt)) {
    retryOrFailServiceDiscovery(
      gatt,
      'required_characteristic_missing',
      '未发现 Oleap 必需的通信或录音特征',
      channelReadySnapshot()
    )
    return
  }

  clearServiceDiscoveryRetryTimeout()
  enableRequiredNotifications(gatt)
}

function byteArrayToNumbers(value: ByteArray | null): Array<number> {
  const result = new Array<number>()
  if (value == null) {
    return result
  }
  for (let i in value.indices) {
    result.push(value[i].toInt() & 0xff)
  }
  return result
}

function numbersToByteArray(value: Array<number>): ByteArray {
  const bytes: ByteArray = new ByteArray(value.length.toInt())
  for (let index: Int = 0; index < value.length; index++) {
    const normalized = value[index] & 0xff
    bytes[index] = normalized.toByte()
  }
  return bytes
}

function normalizeUint32(value: number): number {
  const modulo = 4294967296
  const normalized = value % modulo
  return normalized < 0 ? normalized + modulo : normalized
}

function readUint16Le(bytes: Array<number>, offset: number): number {
  return (bytes[offset] & 0xff) | ((bytes[offset + 1] & 0xff) << 8)
}

function readUint16Be(bytes: Array<number>, offset: number): number {
  return ((bytes[offset] & 0xff) << 8) | (bytes[offset + 1] & 0xff)
}

function readUint32Le(bytes: Array<number>, offset: number): number {
  return normalizeUint32(
    (bytes[offset] & 0xff) +
      ((bytes[offset + 1] & 0xff) * 256) +
      ((bytes[offset + 2] & 0xff) * 65536) +
      ((bytes[offset + 3] & 0xff) * 16777216)
  )
}

function writeUint16Le(bytes: Array<number>, offset: number, value: number): void {
  bytes[offset] = value & 0xff
  bytes[offset + 1] = (value >> 8) & 0xff
}

function writeUint32Le(bytes: Array<number>, offset: number, value: number): void {
  const normalized = normalizeUint32(value)
  bytes[offset] = normalized & 0xff
  bytes[offset + 1] = Math.floor(normalized / 256) & 0xff
  bytes[offset + 2] = Math.floor(normalized / 65536) & 0xff
  bytes[offset + 3] = Math.floor(normalized / 16777216) & 0xff
}

function byteSlice(bytes: Array<number>, start: number, end: number): Array<number> {
  const result = new Array<number>()
  for (let index = start; index < end && index < bytes.length; index++) {
    result.push(bytes[index] & 0xff)
  }
  return result
}

function bytesToHex(bytes: Array<number>, limit: number = 32): string {
  const parts = new Array<string>()
  const count = bytes.length > limit ? limit : bytes.length
  for (let index = 0; index < count; index++) {
    parts.push((bytes[index] & 0xff).toString(16).padStart(2, '0'))
  }
  return parts.join(' ')
}

function utf8Decode(bytes: Array<number>): string {
  let result = ''
  let index = 0
  while (index < bytes.length) {
    const first = bytes[index] & 0xff
    if (first < 0x80) {
      result += String.fromCharCode(first)
      index += 1
      continue
    }
    if (first >= 0xc0 && first < 0xe0 && index + 1 < bytes.length) {
      const code = ((first & 0x1f) << 6) | (bytes[index + 1] & 0x3f)
      result += String.fromCharCode(code)
      index += 2
      continue
    }
    if (first >= 0xe0 && first < 0xf0 && index + 2 < bytes.length) {
      const code = ((first & 0x0f) << 12) |
        ((bytes[index + 1] & 0x3f) << 6) |
        (bytes[index + 2] & 0x3f)
      result += String.fromCharCode(code)
      index += 3
      continue
    }
    if (first >= 0xf0 && index + 3 < bytes.length) {
      const codePoint = ((first & 0x07) << 18) |
        ((bytes[index + 1] & 0x3f) << 12) |
        ((bytes[index + 2] & 0x3f) << 6) |
        (bytes[index + 3] & 0x3f)
      const adjusted = codePoint - 0x10000
      result += String.fromCharCode(0xd800 + (adjusted >> 10))
      result += String.fromCharCode(0xdc00 + (adjusted & 0x3ff))
      index += 4
      continue
    }
    result += '?'
    index += 1
  }
  return result
}

let controlCrcTable: Array<number> | null = null

function getControlCrcTable(): Array<number> {
  if (controlCrcTable != null) {
    return controlCrcTable!
  }
  const table = new Array<number>()
  for (let index = 0; index < 256; index++) {
    let crc = index
    for (let bit = 0; bit < 8; bit++) {
      crc = (crc & 1) != 0
        ? ((crc >>> 1) ^ 0xedb88320)
        : (crc >>> 1)
    }
    table.push(crc >>> 0)
  }
  controlCrcTable = table
  return table
}

function controlCrc32(bytes: Array<number>): number {
  const table = getControlCrcTable()
  let crc = 0xffffffff
  for (let index = 0; index < bytes.length; index++) {
    const tableIndex = (crc ^ (bytes[index] & 0xff)) & 0xff
    crc = ((crc >>> 8) ^ table[tableIndex]) >>> 0
  }
  return (crc ^ 0xffffffff) >>> 0
}

function nextControlSendSn(): number {
  let value = controlSendSn
  controlSendSn = normalizeUint32(controlSendSn + 1)
  if (value == 0) {
    value = controlSendSn
    controlSendSn = normalizeUint32(controlSendSn + 1)
  }
  return value
}

function nextControlAppDpSn(): number {
  const value = controlAppDpSn
  controlAppDpSn = normalizeUint32(controlAppDpSn + 1)
  return value
}

function encodeControlPayload(sendSn: number, askSn: number, command: number, commandPayload: Array<number>): Array<number> {
  const payload = new Array<number>()
  for (let index = 0; index < CONTROL_PAYLOAD_HEADER_LENGTH + commandPayload.length; index++) {
    payload.push(0)
  }
  writeUint32Le(payload, 0, sendSn)
  writeUint32Le(payload, 4, askSn)
  payload[8] = command & 0xff
  for (let index = 0; index < commandPayload.length; index++) {
    payload[CONTROL_PAYLOAD_HEADER_LENGTH + index] = commandPayload[index] & 0xff
  }
  return payload
}

function encodeControlFrame(desc: number, payload: Array<number>): Array<number> {
  const hasCrc = (desc & CONTROL_DESC_CRC_MASK) != 0
  const frameLength = CONTROL_FRAME_HEADER_LENGTH + payload.length + (hasCrc ? CONTROL_CRC_LENGTH : 0)
  const frame = new Array<number>()
  for (let index = 0; index < frameLength; index++) {
    frame.push(0)
  }
  frame[0] = CONTROL_SYNC_FIRST
  frame[1] = CONTROL_SYNC_SECOND
  writeUint16Le(frame, 2, desc)
  frame[4] = CONTROL_MESSAGE_TYPE
  writeUint16Le(frame, 5, payload.length)
  for (let index = 0; index < payload.length; index++) {
    frame[CONTROL_FRAME_HEADER_LENGTH + index] = payload[index] & 0xff
  }
  if (hasCrc) {
    writeUint32Le(frame, CONTROL_FRAME_HEADER_LENGTH + payload.length, controlCrc32(payload))
  }
  return frame
}

function decodeControlFrame(bytes: Array<number>): ControlFrame {
  if (bytes.length < CONTROL_FRAME_HEADER_LENGTH) {
    throw makeError('control_frame_too_short', '控制协议帧长度不足', 'control', true, {
      actualLength: bytes.length
    })
  }
  if (bytes[0] != CONTROL_SYNC_FIRST || bytes[1] != CONTROL_SYNC_SECOND) {
    throw makeError('control_frame_sync_invalid', '控制协议帧头不匹配', 'control', true, {
      first: bytes[0],
      second: bytes[1]
    })
  }
  const desc = readUint16Le(bytes, 2)
  const messageType = bytes[4] & 0xff
  if (messageType != CONTROL_MESSAGE_TYPE) {
    throw makeError('control_frame_type_invalid', '控制协议 MsgType 不匹配', 'control', true, {
      messageType
    })
  }
  const payloadLength = readUint16Le(bytes, 5)
  const hasCrc = (desc & CONTROL_DESC_CRC_MASK) != 0
  const expectedLength = CONTROL_FRAME_HEADER_LENGTH + payloadLength + (hasCrc ? CONTROL_CRC_LENGTH : 0)
  if (bytes.length != expectedLength) {
    throw makeError('control_frame_length_mismatch', '控制协议帧长度不匹配', 'control', true, {
      expectedLength,
      actualLength: bytes.length,
      payloadLength
    })
  }
  const payload = byteSlice(bytes, CONTROL_FRAME_HEADER_LENGTH, CONTROL_FRAME_HEADER_LENGTH + payloadLength)
  if (hasCrc) {
    const expectedCrc = readUint32Le(bytes, CONTROL_FRAME_HEADER_LENGTH + payloadLength)
    const actualCrc = controlCrc32(payload)
    if (expectedCrc != actualCrc) {
      throw makeError('control_crc_mismatch', '控制协议 CRC32 校验失败', 'control', true, {
        expectedCrc,
        actualCrc
      })
    }
  }
  return new ControlFrame(desc, messageType, payload, hasCrc ? readUint32Le(bytes, CONTROL_FRAME_HEADER_LENGTH + payloadLength) : null, (desc & CONTROL_DESC_ERROR_MASK) != 0)
}

function decodeControlPayload(payload: Array<number>): ControlPayload {
  if (payload.length < CONTROL_PAYLOAD_HEADER_LENGTH) {
    throw makeError('control_payload_too_short', '控制协议 Payload 长度不足', 'control', true, {
      actualLength: payload.length
    })
  }
  const command = payload[8] & 0xff
  if (
    command != CONTROL_CMD_DP_QUERY &&
    command != CONTROL_CMD_DP_SEND &&
    command != CONTROL_CMD_DP_WRITE
  ) {
    throw makeError('control_command_unknown', '控制协议 CMD 未知', 'control', true, { command })
  }
  return new ControlPayload(
    readUint32Le(payload, 0),
    readUint32Le(payload, 4),
    command,
    byteSlice(payload, CONTROL_PAYLOAD_HEADER_LENGTH, payload.length)
  )
}

function encodeDpCommandPayload(dpSn: number, dpData: Array<number> | null = null): Array<number> {
  const data = dpData == null ? new Array<number>() : dpData
  const payload = new Array<number>()
  for (let index = 0; index < CONTROL_DP_SEQUENCE_LENGTH + data.length; index++) {
    payload.push(0)
  }
  writeUint32Le(payload, 0, dpSn)
  for (let index = 0; index < data.length; index++) {
    payload[CONTROL_DP_SEQUENCE_LENGTH + index] = data[index] & 0xff
  }
  return payload
}

function decodeDpData(commandPayload: Array<number>): Array<number> {
  if (commandPayload.length < CONTROL_DP_SEQUENCE_LENGTH) {
    throw makeError('control_dp_payload_too_short', '控制协议 DP Payload 长度不足', 'control', true, {
      actualLength: commandPayload.length
    })
  }
  return byteSlice(commandPayload, CONTROL_DP_SEQUENCE_LENGTH, commandPayload.length)
}

function encodeDataPoint(dpId: number, typeCode: number, rawValue: Array<number>): Array<number> {
  const bytes = new Array<number>()
  for (let index = 0; index < 4 + rawValue.length; index++) {
    bytes.push(0)
  }
  bytes[0] = dpId & 0xff
  bytes[1] = typeCode & 0xff
  writeUint16Le(bytes, 2, rawValue.length)
  for (let index = 0; index < rawValue.length; index++) {
    bytes[4 + index] = rawValue[index] & 0xff
  }
  return bytes
}

function decodeDataPoint(bytes: Array<number>): DataPoint | null {
  if (bytes.length == 0) {
    return null
  }
  if (bytes.length < 4) {
    throw makeError('dp_data_too_short', 'DP 数据长度不足', 'control', true, {
      actualLength: bytes.length
    })
  }
  const dpId = bytes[0] & 0xff
  const typeCode = bytes[1] & 0xff
  const declaredLength = readUint16Le(bytes, 2)
  const actualLength = bytes.length - 4
  if (actualLength < declaredLength) {
    throw makeError('dp_data_length_mismatch', 'DP 数据长度不匹配', 'control', true, {
      dpId,
      declaredLength,
      actualLength
    })
  }
  return new DataPoint(dpId, typeCode, byteSlice(bytes, 4, 4 + declaredLength))
}

function readFlexibleInt(dpId: number, bytes: Array<number>): number {
  if (bytes.length == 1) {
    return bytes[0] & 0xff
  }
  if (bytes.length == 2) {
    return readUint16Le(bytes, 0)
  }
  if (bytes.length == 4) {
    return readUint32Le(bytes, 0)
  }
  throw makeError('dp_integer_length_invalid', 'DP 整数长度不支持', 'control', true, {
    dpId,
    length: bytes.length
  })
}

function formatVersionNumber(value: number): string {
  const hex = value.toString(16).padStart(6, '0')
  const part1 = parseInt(hex.substring(0, 2), 10)
  const part2 = parseInt(hex.substring(2, 4), 10)
  const part3 = parseInt(hex.substring(4, 6), 10)
  return `${part1}.${part2}.${part3}`
}

function dpNameOf(dpId: number): string {
  if (dpId == DP_ID_BATTERY) return 'batteryPercentage'
  if (dpId == DP_ID_DEVICE_NAME) return 'deviceName'
  if (dpId == DP_ID_FIRMWARE_VERSION) return 'firmwareVersion'
  if (dpId == DP_ID_HARDWARE_VERSION) return 'hardwareVersion'
  if (dpId == DP_ID_RECORD_STATE) return 'recordState'
  if (dpId == DP_ID_APP_TIME) return 'appTime'
  if (dpId == DP_ID_FLASH_CAPACITY) return 'flashCapacity'
  if (dpId == DP_ID_SN) return 'sn'
  if (dpId == DP_ID_EQ_MODE) return 'eqMode'
  if (dpId == DP_ID_SHORTCUT_KEY) return 'shortcutKey'
  return `dp_${dpId}`
}

function decodeShortcutKeyValue(raw: Array<number>): any {
  return {
    raw
  }
}

function decodeDpValue(dp: DataPoint): any {
  const raw = dp.rawValue
  const dpId = dp.id
  if (dpId == DP_ID_BATTERY) {
    return readFlexibleInt(dpId, raw)
  }
  if (dpId == DP_ID_DEVICE_NAME || dpId == DP_ID_SN) {
    return utf8Decode(raw)
  }
  if (dpId == DP_ID_FIRMWARE_VERSION || dpId == DP_ID_HARDWARE_VERSION) {
    return formatVersionNumber(readFlexibleInt(dpId, raw))
  }
  if (dpId == DP_ID_EQ_MODE) {
    return {
      modeCount: raw.length > 0 ? raw[0] : 0,
      currentMode: raw.length >= 3 ? raw[2] : (raw.length > 0 ? raw[raw.length - 1] : 0),
      raw
    }
  }
  if (dpId == DP_ID_RECORD_STATE) {
    if (raw.length < 6) {
      throw makeError('record_state_length_invalid', '录音状态 DP 长度不足', 'control', true, {
        length: raw.length
      })
    }
    const recordedFrameCount = readUint32Le(raw, 2)
    return {
      state: readUint16Le(raw, 0),
      recordedFrameCount,
      durationMs: recordedFrameCount * 20
    }
  }
  if (dpId == DP_ID_FLASH_CAPACITY) {
    if (raw.length < 4) {
      throw makeError('flash_capacity_length_invalid', 'Flash 容量 DP 长度不足', 'control', true, {
        length: raw.length
      })
    }
    const totalBlocks = readUint16Le(raw, 0)
    const freeBlocks = readUint16Le(raw, 2)
    return {
      totalBlocks,
      freeBlocks,
      totalBytes: totalBlocks * FLASH_BLOCK_BYTES,
      freeBytes: freeBlocks * FLASH_BLOCK_BYTES,
      raw
    }
  }
  if (dpId == DP_ID_SHORTCUT_KEY) {
    return decodeShortcutKeyValue(raw)
  }
  if (dp.typeCode == DP_TYPE_BOOL) {
    return raw.length > 0 && raw[0] != 0
  }
  if (dp.typeCode == DP_TYPE_NUMBER || dp.typeCode == DP_TYPE_ENUM) {
    return readFlexibleInt(dpId, raw)
  }
  if (dp.typeCode == DP_TYPE_STRING) {
    return utf8Decode(raw)
  }
  return raw
}

function normalizeDp(dp: DataPoint): DpEvent {
  const value = decodeDpValue(dp)
  return new DpEvent(dp, dpNameOf(dp.id), value)
}

function emitShortcutKey(event: DpEvent): void {
  pushDiagnostic('shortcut_key_report', {
    dpId: event.dpId,
    name: event.name,
    source: event.source,
    valueLength: event.rawValue.length
  })
  shortcutKeyCallbacks.forEach((callback) => {
    callback(event)
  })
}

function storeAndEmitDp(dp: DataPoint, source: string): DpEvent {
  const event = normalizeDp(dp)
  event.source = source
  dpSnapshot.set(event.dpId, event)
  pushDiagnostic('dp_report', {
    dpId: event.dpId,
    name: event.name,
    source,
    valueLength: event.rawValue.length
  })
  dpCallbacks.forEach((callback) => {
    callback(event)
  })
  if (event.dpId == DP_ID_SHORTCUT_KEY && source == 'report') {
    emitShortcutKey(event)
  }
  return event
}

function buildControlQueryFrame(dpId: number, sendSn: number): Array<number> {
  return encodeControlFrame(
    CONTROL_DESC_REQUEST,
    encodeControlPayload(sendSn, 0, CONTROL_CMD_DP_QUERY, [dpId & 0xff])
  )
}

function buildControlWriteFrame(dpId: number, typeCode: number, rawValue: Array<number>, sendSn: number, appDpSn: number): Array<number> {
  return encodeControlFrame(
    CONTROL_DESC_REQUEST,
    encodeControlPayload(
      sendSn,
      0,
      CONTROL_CMD_DP_WRITE,
      encodeDpCommandPayload(appDpSn, encodeDataPoint(dpId, typeCode, rawValue))
    )
  )
}

function buildControlReportAckFrame(reportSendSn: number): Array<number> {
  const sendSn = nextControlSendSn()
  return encodeControlFrame(
    CONTROL_DESC_ACK,
    encodeControlPayload(sendSn, reportSendSn, CONTROL_CMD_DP_SEND, new Array<number>())
  )
}

function ensureControlReady(): OleapBleNativeError | null {
  const initError = ensureInitialized()
  if (initError != null) {
    return initError
  }
  if (connectedGatt == null || connectedDeviceId == null) {
    return makeError('device_not_connected', '尚未连接 Oleap 设备', 'connection', true)
  }
  if (communicationWriteChar == null || communicationNotifyChar == null || enablingNotifications) {
    return makeError('control_channel_not_ready', '控制协议通道尚未就绪', 'control', true, channelReadySnapshot())
  }
  return null
}

function completeControlRequest(request: ControlTransaction | null, value: DpEvent | null): void {
  if (request == null || request.completed == true) {
    return
  }
  clearControlTimeout()
  request.completed = true
  if (activeControlTransaction == request) {
    activeControlTransaction = null
  }
  request.resolve(value)
  processNextControlTransaction()
}

function failControlRequest(request: ControlTransaction | null, error: OleapBleNativeError, emit: boolean = true): void {
  if (request == null || request.completed == true) {
    return
  }
  clearControlTimeout()
  if (activeControlTransaction == request) {
    activeControlTransaction = null
  }
  rejectControlRequest(request, error, emit)
  processNextControlTransaction()
}

function sendControlAttempt(request: ControlTransaction): void {
  if (request.completed == true) {
    return
  }
  if (request.generation != sessionGeneration) {
    failControlRequest(
      request,
      makeError('control_stale_generation', '控制协议 session 已失效', 'control', true, {
        requestGeneration: request.generation,
        currentGeneration: sessionGeneration
      })
    )
    return
  }
  request.attempts += 1
  pushDiagnostic('control_write_attempt', {
    kind: request.kind,
    dpId: request.dpId,
    sendSn: request.sendSn,
    attempt: request.attempts,
    maxAttempts: CONTROL_MAX_ATTEMPTS,
    length: request.frame.length
  })
  writeCommunicationBytes(request.frame, true)
    .then(() => {
      if (request.completed == true || activeControlTransaction != request) {
        return
      }
      controlTimeoutId = setTimeout(() => {
        if (request.completed == true || activeControlTransaction != request) {
          return
        }
        clearControlTimeout()
        if (request.attempts < CONTROL_MAX_ATTEMPTS) {
          pushDiagnostic('control_retry', {
            kind: request.kind,
            dpId: request.dpId,
            sendSn: request.sendSn,
            attempts: request.attempts
          })
          sendControlAttempt(request)
          return
        }
        failControlRequest(
          request,
          makeError('control_timeout', '控制协议事务超时', 'control', true, {
            kind: request.kind,
            dpId: request.dpId,
            sendSn: request.sendSn,
            attempts: request.attempts,
            timeoutMs: DEFAULT_CONTROL_TIMEOUT_MS
          })
        )
      }, DEFAULT_CONTROL_TIMEOUT_MS)
    })
    .catch((error) => {
      failControlRequest(
        request,
        makeError('control_write_failed', '控制协议写入失败', 'control', true, {
          kind: request.kind,
          dpId: request.dpId,
          sendSn: request.sendSn,
          error: `${error}`
        })
      )
    })
}

function processNextControlTransaction(): void {
  if (activeControlTransaction != null) {
    return
  }
  const request = controlTransactionQueue.shift()
  if (request == null) {
    return
  }
  activeControlTransaction = request
  sendControlAttempt(request)
}

function enqueueControlTransaction(kind: string, dpId: number, frame: Array<number>, sendSn: number): Promise<DpEvent | null> {
  const readyError = ensureControlReady()
  if (readyError != null) {
    return rejectWith<DpEvent | null>(readyError)
  }
  return new Promise<DpEvent | null>((resolve, reject) => {
    const request = new ControlTransaction(kind, dpId, frame, sendSn, sessionGeneration, resolve, reject)
    controlTransactionQueue.push(request)
    pushDiagnostic('control_transaction_enqueued', {
      kind,
      dpId,
      sendSn,
      queueDepth: controlTransactionQueue.length,
      generation: sessionGeneration
    })
    processNextControlTransaction()
  })
}

function queryDp(dpId: number): Promise<DpEvent | null> {
  const sendSn = nextControlSendSn()
  return enqueueControlTransaction('query', dpId, buildControlQueryFrame(dpId, sendSn), sendSn)
}

function writeDp(dpId: number, typeCode: number, rawValue: Array<number>): Promise<DpEvent | null> {
  const sendSn = nextControlSendSn()
  const appDpSn = nextControlAppDpSn()
  return enqueueControlTransaction(
    'write',
    dpId,
    buildControlWriteFrame(dpId, typeCode, rawValue, sendSn, appDpSn),
    sendSn
  )
}

function ackControlReport(sendSn: number): void {
  const frame = buildControlReportAckFrame(sendSn)
  writeCommunicationBytes(frame, true)
    .then(() => {
      pushDiagnostic('control_device_report_ack_sent', { askSn: sendSn })
    })
    .catch((error) => {
      emitError(
        makeError('control_ack_failed', '控制协议主动上报 ACK 发送失败', 'control', true, {
          askSn: sendSn,
          error: `${error}`
        })
      )
    })
}

function handleControlDpSend(frame: ControlFrame, payload: ControlPayload): void {
  const dpData = decodeDpData(payload.commandPayload)
  const decoded = decodeDataPoint(dpData)
  if (payload.askSn == 0) {
    ackControlReport(payload.sendSn)
  }
  if (decoded == null) {
    return
  }
  const event = storeAndEmitDp(decoded, payload.askSn == 0 ? 'report' : 'response')
  const active = activeControlTransaction
  if (
    payload.askSn != 0 &&
    active != null &&
    active.kind == 'query' &&
    payload.askSn == active.sendSn
  ) {
    pushDiagnostic('control_response_matched', {
      kind: active.kind,
      dpId: active.dpId,
      sendSn: active.sendSn,
      askSn: payload.askSn
    })
    completeControlRequest(active, event)
  } else if (payload.askSn != 0 && frame.error) {
    pushDiagnostic('control_dp_send_error', {
      dpId: decoded.id,
      sendSn: payload.sendSn,
      askSn: payload.askSn
    })
  }
}

function handleControlDpWrite(frame: ControlFrame, payload: ControlPayload): void {
  const active = activeControlTransaction
  if (
    active == null ||
    active.kind != 'write' ||
    payload.askSn != active.sendSn
  ) {
    return
  }
  let rollback: DpEvent | null = null
  const dpData = decodeDpData(payload.commandPayload)
  const decoded = decodeDataPoint(dpData)
  if (decoded != null) {
    rollback = storeAndEmitDp(decoded, frame.error ? 'rollback' : 'writeResponse')
  }
  if (frame.error) {
    failControlRequest(
      active,
      makeError('control_write_rejected', '设备拒绝控制协议写入', 'control', true, {
        dpId: active.dpId,
        sendSn: active.sendSn,
        rollback
      })
    )
    return
  }
  pushDiagnostic('control_response_matched', {
    kind: active.kind,
    dpId: active.dpId,
    sendSn: active.sendSn,
    askSn: payload.askSn
  })
  completeControlRequest(active, rollback)
}

function handleControlIncomingFrame(bytes: Array<number>, generation: number): void {
  if (generation != sessionGeneration) {
    pushDiagnostic('stale_control_frame_ignored', { generation, current: sessionGeneration })
    return
  }
  try {
    const frame = decodeControlFrame(bytes)
    const payload = decodeControlPayload(frame.payload)
    pushDiagnostic('control_response_received', {
      sendSn: payload.sendSn,
      askSn: payload.askSn,
      command: payload.command,
      payloadLength: frame.payload.length,
      error: frame.error
    })
    if (payload.command == CONTROL_CMD_DP_SEND) {
      handleControlDpSend(frame, payload)
      return
    }
    if (payload.command == CONTROL_CMD_DP_WRITE) {
      handleControlDpWrite(frame, payload)
    }
  } catch (error) {
    const maybeError = asNativeError(error)
    let nativeError: OleapBleNativeError
    if (maybeError != null) {
      nativeError = maybeError
    } else {
      nativeError = makeError('control_protocol_error', '控制协议解析失败', 'control', true, {
        error: `${error}`,
        head: bytesToHex(bytes)
      })
    }
    emitError(nativeError)
  }
}

function handleCommunicationNotify(bytes: Array<number>, generation: number): void {
  if (generation != sessionGeneration) {
    pushDiagnostic('stale_communication_notify_ignored', { generation, current: sessionGeneration })
    return
  }
  pushDiagnostic('communication_notify', {
    length: bytes.length,
    generation
  })
  handleControlIncomingFrame(bytes, generation)
}

function buildRecordingCommand(command: number, payload: Array<number> | null = null): Array<number> {
  const data = payload == null ? new Array<number>() : payload
  const frame = new Array<number>()
  for (let index = 0; index < 4 + data.length; index++) {
    frame.push(0)
  }
  frame[0] = (command >> 8) & 0xff
  frame[1] = command & 0xff
  writeUint16Le(frame, 2, data.length)
  for (let index = 0; index < data.length; index++) {
    frame[4 + index] = data[index] & 0xff
  }
  return frame
}

function buildFlashCommand(command: number, payload: Array<number>, needCrc: boolean = true): Array<number> {
  const frame = buildRecordingCommand(command, payload)
  if (!needCrc) {
    return frame
  }
  const crcInput = byteSlice(frame, 2, 4 + payload.length)
  const crc = controlCrc32(crcInput)
  frame.push(crc & 0xff)
  frame.push(Math.floor(crc / 256) & 0xff)
  frame.push(Math.floor(crc / 65536) & 0xff)
  frame.push(Math.floor(crc / 16777216) & 0xff)
  return frame
}

function uint32Payload(value: number): Array<number> {
  const payload = [0, 0, 0, 0]
  writeUint32Le(payload, 0, value)
  return payload
}

function buildFlashGetFileCountCommand(): Array<number> {
  return buildFlashCommand(FLASH_COMMAND_GET_FILE_COUNT, [0], false)
}

function buildFlashGetFileInfoCommand(fileId: number): Array<number> {
  return buildFlashCommand(FLASH_COMMAND_GET_FILE_INFO, uint32Payload(fileId), true)
}

function buildFlashDownloadCommand(fileId: number, startAddress: number, continuous: boolean = true): Array<number> {
  const payload = new Array<number>()
  for (let index = 0; index < 12; index++) {
    payload.push(0)
  }
  writeUint32Le(payload, 0, continuous ? 0 : 1)
  writeUint32Le(payload, 4, fileId)
  writeUint32Le(payload, 8, startAddress)
  return buildFlashCommand(FLASH_COMMAND_DOWNLOAD, payload, true)
}

function buildFlashStopUploadCommand(): Array<number> {
  return buildFlashCommand(FLASH_COMMAND_STOP_UPLOAD, [0, 0], false)
}

function buildFlashDeleteCommand(fileId: number): Array<number> {
  return buildFlashCommand(FLASH_COMMAND_DELETE, uint32Payload(fileId), true)
}

function recordingSceneCommandOf(value: any | null): RecordingSceneCommand {
  const raw = value == null ? 'personal' : `${value}`
  if (raw == 'personal' || raw == '1') {
    return new RecordingSceneCommand('personal', RECORDING_COMMAND_PERSONAL)
  }
  if (raw == 'call' || raw == '2') {
    return new RecordingSceneCommand('call', RECORDING_COMMAND_CALL)
  }
  if (raw == 'media' || raw == '3') {
    return new RecordingSceneCommand('media', RECORDING_COMMAND_MEDIA)
  }
  if (raw == 'ambient' || raw == '4') {
    return new RecordingSceneCommand('ambient', RECORDING_COMMAND_AMBIENT)
  }
  if (raw == '6') {
    return new RecordingSceneCommand('scene_6', RECORDING_COMMAND_SCENE_6)
  }
  if (raw == '7') {
    return new RecordingSceneCommand('scene_7', RECORDING_COMMAND_SCENE_7)
  }
  throw makeError('invalid_recording_scene', '录音场景不支持', 'recording', false, { scene: raw })
}

function requestedRecordingFormatOf(options: any | null): string {
  const format = optionString(options, 'format', 'wav')!
  if (format == 'wav' || format == 'mp3') {
    return format
  }
  throw makeError('invalid_recording_format', '录音输出格式仅支持 wav 或 mp3', 'recording', false, { format })
}

function recordingBitrateOf(opusConfig: number): number {
  const key = (opusConfig >> 4) & 0x0f
  if (key == 1) return 24000
  if (key == 2) return 16000
  return 32000
}

function recordingChannelsOf(opusConfig: number): number {
  const channels = opusConfig & 0x0f
  return channels == 0 ? 1 : channels
}

function recordingFrameTimeMs(frameLen: number, bitrate: number): number {
  if (bitrate <= 0) {
    return 20
  }
  const value = Math.floor(frameLen * 8000 / bitrate)
  return value > 0 ? value : 20
}

function splitRecordingFrames(bytes: Array<number>): RecordingResponse {
  const response = new RecordingResponse()
  response.kind = 'frames'
  let offset = 0
  while (offset < bytes.length) {
    if (bytes.length - offset < RECORDING_FRAME_HEADER_LENGTH) {
      response.badFrames += 1
      break
    }
    const frameLen = bytes[offset] & 0xff
    if (frameLen <= 0) {
      response.badFrames += 1
      break
    }
    const end = offset + RECORDING_FRAME_HEADER_LENGTH + frameLen
    if (end > bytes.length) {
      response.badFrames += 1
      break
    }
    const opusConfig = bytes[offset + 1] & 0xff
    const bitrate = recordingBitrateOf(opusConfig)
    const channels = recordingChannelsOf(opusConfig)
    response.frames.push(new RecordingFrame(
      frameLen,
      opusConfig,
      readUint16Le(bytes, offset + 2),
      bitrate,
      channels,
      RECORDING_SAMPLE_RATE,
      recordingFrameTimeMs(frameLen, bitrate),
      byteSlice(bytes, offset + RECORDING_FRAME_HEADER_LENGTH, end),
      byteSlice(bytes, offset, end)
    ))
    offset = end
  }
  return response
}

function parseFlashRecordTime(bytes: Array<number>, offset: number): string | null {
  let allUnknown = true
  for (let index = 0; index < 6; index++) {
    if ((bytes[offset + index] & 0xff) != 0xff) {
      allUnknown = false
    }
  }
  if (allUnknown) {
    return null
  }
  const year = 2000 + (bytes[offset] & 0xff)
  const month = `${bytes[offset + 1] & 0xff}`.padStart(2, '0')
  const day = `${bytes[offset + 2] & 0xff}`.padStart(2, '0')
  const hour = `${bytes[offset + 3] & 0xff}`.padStart(2, '0')
  const minute = `${bytes[offset + 4] & 0xff}`.padStart(2, '0')
  const second = `${bytes[offset + 5] & 0xff}`.padStart(2, '0')
  return `${year}-${month}-${day}T${hour}:${minute}:${second}+08:00`
}

function parseFlashFileInfo(bytes: Array<number>, offset: number): FlashFileInfo {
  const btAddr = byteSlice(bytes, offset + 12, offset + 18)
  const info = new FlashFileInfo()
  info.fileVersion = readUint16Le(bytes, offset)
  info.blockNum = readUint16Le(bytes, offset + 2)
  info.fileId = readUint32Le(bytes, offset + 4)
  info.fileLength = readUint32Le(bytes, offset + 8)
  info.btAddr = btAddr
  info.btAddrHex = bytesToHex(btAddr, btAddr.length).split(' ').join(':').toUpperCase()
  info.recordTime = parseFlashRecordTime(bytes, offset + 20)
  info.recordType = bytes[offset + 26] & 0xff
  info.recordCh = bytes[offset + 27] & 0xff
  info.channels = bytes[offset + 27] & 0xff
  info.sampleRate = readUint16Le(bytes, offset + 28)
  info.bitRate = readUint16Le(bytes, offset + 30)
  return info
}

function ensureFlashResponseLength(bytes: Array<number>, command: number, minimumDeclaredLength: number): number {
  if (bytes.length < 4) {
    throw makeError('flash_response_too_short', 'Flash 响应长度不足', 'flash', true, {
      command,
      length: bytes.length
    })
  }
  const declaredLength = readUint16Le(bytes, 2)
  if (declaredLength < minimumDeclaredLength || bytes.length < 4 + declaredLength) {
    throw makeError('flash_response_length_mismatch', 'Flash 响应参数长度不匹配', 'flash', true, {
      command,
      declaredLength,
      minimumDeclaredLength,
      actualLength: bytes.length - 4
    })
  }
  return declaredLength
}

function flashResponseCrcOf(bytes: Array<number>, declaredLength: number): number | null {
  const crcOffset = 4 + declaredLength
  if (bytes.length < crcOffset + 4) {
    return null
  }
  return readUint32Le(bytes, crcOffset)
}

function parseFlashFileCountResponse(bytes: Array<number>): RecordingResponse {
  const declaredLength = ensureFlashResponseLength(bytes, FLASH_COMMAND_GET_FILE_COUNT, 8)
  const fileCount = readUint32Le(bytes, 4)
  const fileStartId = readUint32Le(bytes, 8)
  const response = new RecordingResponse()
  response.kind = 'flash_count'
  response.command = FLASH_COMMAND_GET_FILE_COUNT
  response.fileCount = fileCount
  response.fileStartId = fileStartId
  response.empty = fileCount == 0 || fileCount == FLASH_NO_FILE_VALUE || fileStartId == FLASH_NO_FILE_VALUE
  response.crc32 = flashResponseCrcOf(bytes, declaredLength)
  return response
}

function parseFlashFileInfoResponse(bytes: Array<number>): RecordingResponse {
  const declaredLength = ensureFlashResponseLength(bytes, FLASH_COMMAND_GET_FILE_INFO, 36)
  const response = new RecordingResponse()
  response.kind = 'flash_info'
  response.command = FLASH_COMMAND_GET_FILE_INFO
  response.isFileExist = readUint32Le(bytes, 4) == 1
  response.fileInfo = parseFlashFileInfo(bytes, 8)
  response.crc32 = flashResponseCrcOf(bytes, declaredLength)
  return response
}

function parseFlashDownloadResponse(bytes: Array<number>): RecordingResponse {
  const declaredLength = ensureFlashResponseLength(bytes, FLASH_COMMAND_DOWNLOAD, 8)
  const dataCapacity = declaredLength - 8
  const dataStart = 12
  const dataEnd = dataStart + dataCapacity
  const returnLength = readUint32Le(bytes, 4)
  const response = new RecordingResponse()
  response.kind = 'flash_download'
  response.command = FLASH_COMMAND_DOWNLOAD
  response.returnLength = returnLength
  response.startAddress = readUint32Le(bytes, 8)
  response.fileData = byteSlice(bytes, dataStart, dataEnd)
  response.dataCapacity = dataCapacity
  response.completed = returnLength < dataCapacity
  response.readError = returnLength == FLASH_READ_ERROR_VALUE
  response.fileMissing = returnLength == FLASH_NO_FILE_VALUE
  response.crc32 = flashResponseCrcOf(bytes, declaredLength)
  return response
}

function parseFlashDeleteResponse(bytes: Array<number>): RecordingResponse {
  const declaredLength = ensureFlashResponseLength(bytes, FLASH_COMMAND_DELETE, 8)
  const response = new RecordingResponse()
  response.kind = 'flash_delete'
  response.command = FLASH_COMMAND_DELETE
  response.status = readUint32Le(bytes, 4)
  response.fileId = readUint32Le(bytes, 8)
  response.crc32 = flashResponseCrcOf(bytes, declaredLength)
  return response
}

function parseRecordingResponse(bytes: Array<number>): RecordingResponse {
  if (bytes.length >= 2) {
    const command = readUint16Be(bytes, 0)
    if (command == FLASH_COMMAND_GET_FILE_COUNT) {
      return parseFlashFileCountResponse(bytes)
    }
    if (command == FLASH_COMMAND_GET_FILE_INFO) {
      return parseFlashFileInfoResponse(bytes)
    }
    if (command == FLASH_COMMAND_DOWNLOAD) {
      return parseFlashDownloadResponse(bytes)
    }
    if (command == FLASH_COMMAND_DELETE) {
      return parseFlashDeleteResponse(bytes)
    }
    if (command == RECORDING_RESPONSE_START || command == RECORDING_RESPONSE_STOP) {
      if (bytes.length < 4) {
        throw makeError('recording_response_too_short', '录音响应长度不足', 'recording', true, {
          length: bytes.length
        })
      }
      const declaredLength = readUint16Le(bytes, 2)
      if (bytes.length < 4 + declaredLength) {
        throw makeError('recording_response_length_mismatch', '录音响应参数长度不匹配', 'recording', true, {
          declaredLength,
          actualLength: bytes.length - 4
        })
      }
      if (command == RECORDING_RESPONSE_START) {
        if (declaredLength < 4 || bytes.length < 8) {
          throw makeError('recording_start_response_too_short', '录音启动响应长度不足', 'recording', true, {
            declaredLength,
            actualLength: bytes.length
          })
        }
        const response = new RecordingResponse()
        response.kind = 'start'
        response.command = command
        response.startReason = bytes[4] & 0xff
        response.recordChannel = bytes[5] & 0xff
        response.packetLength = readUint16Le(bytes, 6)
        return response
      }
      if (declaredLength < 2 || bytes.length < 6) {
        throw makeError('recording_stop_response_too_short', '录音停止响应长度不足', 'recording', true, {
          declaredLength,
          actualLength: bytes.length
        })
      }
      const response = new RecordingResponse()
      response.kind = 'stop'
      response.command = command
      response.stopReason = bytes[4] & 0xff
      response.stopReasonScene = bytes[5] & 0xff
      return response
    }
  }
  return splitRecordingFrames(bytes)
}

function recordingOutputBasePath(): string {
  const cachePath: string | null = UTSAndroid.getAppCachePath() as string
  if (cachePath != null && cachePath.length > 0) {
    return `${cachePath}/oleap-recordings`
  }
  const context = getContext()
  if (context == null) {
    return ''
  }
  return `${context.getCacheDir().getAbsolutePath()}/oleap-recordings`
}

function openRecordingSessionFiles(session: RecordingSession): void {
  const basePath = recordingOutputBasePath()
  if (basePath.length == 0) {
    throw makeError('recording_output_path_missing', '无法获取录音输出目录', 'recording', true)
  }
  const dir = new File(basePath)
  if (!dir.exists() && !dir.mkdirs()) {
    throw makeError('recording_output_dir_create_failed', '创建录音输出目录失败', 'recording', true, {
      basePath
    })
  }
  session.opusRawPath = `${basePath}/${session.sessionId}.opusraw`
  session.framesPath = `${basePath}/${session.sessionId}.oleapframes`
  const opusFile = new File(session.opusRawPath)
  const framesFile = new File(session.framesPath)
  session.opusRawStream = new FileOutputStream(opusFile, false)
  session.framesStream = new FileOutputStream(framesFile, false)
}

function appendBytesToOutputStream(stream: FileOutputStream | null, bytes: Array<number>): void {
  if (stream == null || bytes.length == 0) {
    return
  }
  stream.write(numbersToByteArray(bytes))
}

function closeOutputStream(stream: FileOutputStream | null): void {
  if (stream == null) {
    return
  }
  stream.flush()
  stream.close()
}

function closeRecordingSessionStreams(session: RecordingSession | null): void {
  if (session == null) {
    return
  }
  try {
    closeOutputStream(session.opusRawStream)
  } catch (error) {
    emitError(makeError('recording_file_close_failed', '关闭 OPUS payload 文件失败', 'recording', true, {
      sessionId: session.sessionId,
      error: `${error}`
    }))
  }
  try {
    closeOutputStream(session.framesStream)
  } catch (error) {
    emitError(makeError('recording_file_close_failed', '关闭 OPUS 帧诊断文件失败', 'recording', true, {
      sessionId: session.sessionId,
      error: `${error}`
    }))
  }
  session.opusRawStream = null
  session.framesStream = null

  // 关闭实时音频流
  if (session.enableRealtimeStream) {
    try {
      closeOutputStream(session.realtimeOutputStream)
    } catch (error) {
      emitError(makeError('realtime_output_close_failed', '关闭实时解码输出文件失败', 'recording', true, {
        sessionId: session.sessionId,
        error: `${error}`
      }))
    }
    session.realtimeOutputStream = null
  }
}

function createRecordingSession(scene: string, startResponse: RecordingResponse): RecordingSession {
  recordingSessionCounter += 1
  const timestamp = new Date().getTime()
  const session = new RecordingSession(
    `android-${timestamp}-${recordingSessionCounter}`,
    scene,
    sessionGeneration,
    startResponse.recordChannel,
    startResponse.packetLength
  )
  openRecordingSessionFiles(session)
  return session
}

function createFlashRecordingSession(fileInfo: FlashFileInfo): RecordingSession {
  const startResponse = new RecordingResponse()
  startResponse.recordChannel = 0
  startResponse.packetLength = RECORDING_DECODER_FRAME_BYTES
  const session = createRecordingSession('flash', startResponse)
  session.source = 'flash'
  session.fileId = fileInfo.fileId
  session.expectedBytes = fileInfo.fileLength
  session.downloadedBytes = 0
  session.progress = 0
  session.sampleRate = fileInfo.sampleRate
  session.channels = fileInfo.channels
  session.bitrate = fileInfo.bitRate
  return session
}

function initRealtimeDecoder(session: RecordingSession): void {
  const decoder = new OpusDecoder()
  if (!decoder.init()) {
    throw makeError('realtime_decoder_init_failed', '实时解码器初始化失败', 'recording', true, {
      sessionId: session.sessionId
    })
  }

  const outputPath = recordingDecodedOutputPath(session, session.realtimeFormat)
  deleteFileSilently(outputPath)

  const output = new FileOutputStream(new File(outputPath), false)

  // 写入 WAV 占位头（44字节）
  output.write(numbersToByteArray(
    wavHeaderBytes(0, RECORDING_SAMPLE_RATE, 1, RECORDING_PCM_BITS_PER_SAMPLE)
  ))

  session.enableRealtimeStreamr = decoder
  session.realtimeOutputPath = outputPath
  session.realtimeOutputStream = output
  session.realtimePcmBytes = 0
  session.enableRealtimeStreamdFrames = 0
  session.realtimeFailedFrames = 0

  pushDiagnostic('realtime_decoder_initialized', {
    sessionId: session.sessionId,
    outputPath,
    format: session.realtimeFormat
  })
}

function finalizeRealtimeDecoding(session: RecordingSession): RecordingResult {
  try {
    // 处理剩余的待解码帧
    const decoder = session.enableRealtimeStreamr
    const outputStream = session.realtimeOutputStream
    if (decoder != null && outputStream != null && session.realtimePendingFrames.length > 0) {
      const remainingFrames = session.realtimePendingFrames.length
      let remainingDecodedFrames: Int = 0
      let remainingFailedFrames: Int = 0

      pushDiagnostic('realtime_decode_processing_remaining', {
        sessionId: session.sessionId,
        remainingFrames
      })

      for (let index = 0; index < remainingFrames; index++) {
        const rawFrame = session.realtimePendingFrames[index]
        try {
          const payload = opusPayloadFromFrame(rawFrame)
          const pcm = decoder.decode(payload, RECORDING_DECODER_FRAME_SAMPLES.toInt())

          if (pcm != null) {
            outputStream.write(pcm)
            session.realtimePcmBytes += pcm.size
            remainingDecodedFrames += 1
          } else {
            remainingFailedFrames += 1
          }
        } catch (error) {
          remainingFailedFrames += 1
        }
      }

      session.enableRealtimeStreamdFrames += remainingDecodedFrames
      session.realtimeFailedFrames += remainingFailedFrames
      session.realtimePendingFrames.splice(0, remainingFrames)

      pushDiagnostic('realtime_decode_remaining_completed', {
        sessionId: session.sessionId,
        decodedFrames: remainingDecodedFrames,
        failedFrames: remainingFailedFrames
      })
    }

    // 关闭输出流
    if (session.realtimeOutputStream != null) {
      session.realtimeOutputStream.close()
      session.realtimeOutputStream = null
    }

    // 释放 decoder
    if (decoder != null) {
      try { decoder.release() } catch (_) {}
      session.enableRealtimeStreamr = null
    }

    // 检查解码结果
    if (session.enableRealtimeStreamdFrames <= 0 || session.realtimePcmBytes <= 0) {
      deleteFileSilently(session.realtimeOutputPath)
      throw makeError('realtime_decode_empty', '实时解码没有生成有效 PCM 数据', 'recording', true, {
        sessionId: session.sessionId,
        decodedFrames: session.enableRealtimeStreamdFrames,
        pcmBytes: session.realtimePcmBytes
      })
    }

    // 检查失败率
    const totalAttempts = session.enableRealtimeStreamdFrames + session.realtimeFailedFrames
    if (totalAttempts > 0 && session.realtimeFailedFrames / totalAttempts > RECORDING_DECODE_FAILURE_THRESHOLD) {
      deleteFileSilently(session.realtimeOutputPath)
      throw makeError('realtime_decode_corruption_threshold', '实时解码失败帧比例过高', 'recording', true, {
        sessionId: session.sessionId,
        decodedFrames: session.enableRealtimeStreamdFrames,
        failedFrames: session.realtimeFailedFrames,
        failureThreshold: RECORDING_DECODE_FAILURE_THRESHOLD
      })
    }

    // 回写 WAV 头
    rewriteWavHeader(
      session.realtimeOutputPath,
      session.realtimePcmBytes,
      RECORDING_SAMPLE_RATE,
      1,
      RECORDING_PCM_BITS_PER_SAMPLE
    )

    emitDecodeProgress({
      sessionId: session.sessionId,
      phase: 'finalizing',
      progress: 100
    })

    const outputFile = new File(session.realtimeOutputPath)
    const outputSize = outputFile.length()

    pushDiagnostic('realtime_decode_completed', {
      sessionId: session.sessionId,
      decodedFrames: session.enableRealtimeStreamdFrames,
      failedFrames: session.realtimeFailedFrames,
      pcmBytes: session.realtimePcmBytes,
      outputSize
    })

    // 返回结果
    const result = new RecordingResult(session.realtimeOutputPath, session.realtimeFormat)
    result.durationMs = session.durationMs
    result.sampleRate = RECORDING_SAMPLE_RATE
    result.channels = 1
    result.frameCount = session.frameCount
    result.frameLen = session.frameLen
    result.decodedFrames = session.enableRealtimeStreamdFrames
    result.failedFrames = session.realtimeFailedFrames
    result.pcmBytes = session.realtimePcmBytes
    result.lostFrames = session.lostFrames
    result.outOfOrderFrames = session.outOfOrderFrames
    result.badFrames = session.badFrames
    result.size = outputSize
    return result
  } catch (error) {
    // 清理资源
    if (session.realtimeOutputStream != null) {
      try { session.realtimeOutputStream.close() } catch (_) {}
      session.realtimeOutputStream = null
    }
    const cleanupDecoder = session.enableRealtimeStreamr
    if (cleanupDecoder != null) {
      try { cleanupDecoder.release() } catch (_) {}
      session.enableRealtimeStreamr = null
    }
    const maybeError = asNativeError(error)
    if (maybeError != null) {
      throw maybeError
    }
    throw makeError('realtime_decode_finalize_failed', '实时解码完成失败', 'recording', true, {
      sessionId: session.sessionId,
      error: `${error}`
    })
  }
}

function recordingSessionSummary(session: RecordingSession): UTSJSONObject {
  return {
    sessionId: session.sessionId,
    scene: session.scene,
    source: session.source == null ? 'realtime' : session.source,
    fileId: session.fileId == null ? null : session.fileId,
    startedAt: session.startedAt,
    stoppedAt: session.stoppedAt,
    durationMs: session.durationMs,
    sampleRate: session.sampleRate,
    channels: session.channels,
    bitrate: session.bitrate,
    frameCount: session.frameCount,
    frameLen: session.frameLen,
    variableFrameLen: session.variableFrameLen,
    lostFrames: session.lostFrames,
    outOfOrderFrames: session.outOfOrderFrames,
    badFrames: session.badFrames,
    opusPayloadBytes: session.opusPayloadBytes,
    framedBytes: session.framedBytes,
    downloadedBytes: session.downloadedBytes == null ? null : session.downloadedBytes,
    expectedBytes: session.expectedBytes == null ? null : session.expectedBytes,
    opusRawPath: session.opusRawPath,
    framesPath: session.framesPath,
    recordChannel: session.recordChannel,
    packetLength: session.packetLength
  } as UTSJSONObject
}

function emitRecordingProgress(session: RecordingSession, force: boolean = false): void {
  const now = new Date().getTime()
  if (!force && now - session.lastProgressAt < RECORDING_PROGRESS_THROTTLE_MS) {
    return
  }
  session.lastProgressAt = now
  const event = {
    sessionId: session.sessionId,
    durationMs: session.durationMs,
    frameCount: session.frameCount,
    frameLen: session.frameLen,
    variableFrameLen: session.variableFrameLen,
    lostFrames: session.lostFrames,
    outOfOrderFrames: session.outOfOrderFrames,
    badFrames: session.badFrames,
    sampleRate: session.sampleRate,
    channels: session.channels,
    bitrate: session.bitrate,
    flash: session.source == 'flash',
    source: session.source == null ? 'realtime' : session.source,
    progress: session.progress == null ? null : session.progress,
    fileId: session.fileId == null ? null : session.fileId,
    downloadedBytes: session.downloadedBytes == null ? null : session.downloadedBytes,
    expectedBytes: session.expectedBytes == null ? null : session.expectedBytes
  }
  recordingProgressCallbacks.forEach((callback) => {
    callback(event)
  })
}

function emitDecodeProgress(event: any): void {
  decodeProgressCallbacks.forEach((callback) => {
    callback(event)
  })
}

function emitWaveformData(event: any): void {
  waveformDataCallbacks.forEach((callback) => {
    callback(event)
  })
}


function completeRecordingCommand(request: RecordingCommandRequest | null, value: any): void {
  if (request == null || request.completed == true) {
    return
  }
  clearRecordingCommandTimeout()
  request.completed = true
  if (pendingRecordingCommand == request) {
    pendingRecordingCommand = null
  }
  request.resolve(value)
}

function startRecordingCommandTimeout(request: RecordingCommandRequest): void {
  clearRecordingCommandTimeout()
  recordingCommandTimeoutId = setTimeout(() => {
    if (pendingRecordingCommand != request || request.completed == true) {
      return
    }
    rejectRecordingCommand(
      request,
      makeError('recording_command_timeout', '录音协议命令超时', 'recording', true, {
        kind: request.kind,
        timeoutMs: DEFAULT_RECORDING_COMMAND_TIMEOUT_MS,
        generation: request.generation
      })
    )
  }, DEFAULT_RECORDING_COMMAND_TIMEOUT_MS)
}

function ensureRecordingReady(): OleapBleNativeError | null {
  const initError = ensureInitialized()
  if (initError != null) {
    return initError
  }
  if (connectedGatt == null || connectedDeviceId == null) {
    return makeError('device_not_connected', '尚未连接 Oleap 设备', 'connection', true)
  }
  if (recordWriteChar == null || recordNotifyChar == null || enablingNotifications) {
    return makeError('record_channel_not_ready', '录音协议通道尚未就绪', 'recording', true, channelReadySnapshot())
  }
  return null
}

function ensureFlashReady(): OleapBleNativeError | null {
  const readyError = ensureRecordingReady()
  if (readyError != null) {
    return readyError
  }
  if (recordingSession != null || pendingRecordingCommand != null) {
    return makeError('record_active', '实时录音中，不能操作 Flash 文件', 'flash', true)
  }
  if (flashSession != null) {
    return makeError('flash_download_active', 'Flash 下载中，不能启动新的 Flash 命令', 'flash', true)
  }
  return null
}

function completeFlashCommand(request: FlashCommandRequest | null, value: RecordingResponse): void {
  if (request == null || request.completed == true) {
    return
  }
  clearFlashCommandTimeout()
  request.completed = true
  if (pendingFlashCommand == request) {
    pendingFlashCommand = null
  }
  request.resolve(value)
}

function startFlashCommandTimeout(request: FlashCommandRequest): void {
  clearFlashCommandTimeout()
  flashCommandTimeoutId = setTimeout(() => {
    if (pendingFlashCommand != request || request.completed == true) {
      return
    }
    rejectFlashCommand(
      request,
      makeError('flash_command_timeout', 'Flash 协议命令超时', 'flash', true, {
        kind: request.kind,
        timeoutMs: DEFAULT_FLASH_COMMAND_TIMEOUT_MS,
        generation: request.generation
      })
    )
  }, DEFAULT_FLASH_COMMAND_TIMEOUT_MS)
}

function sendFlashCommand(kind: string, command: Array<number>): Promise<RecordingResponse> {
  const readyError = ensureFlashReady()
  if (readyError != null) {
    return rejectWith<RecordingResponse>(readyError)
  }
  const pendingCommand = pendingFlashCommand
  if (pendingCommand != null) {
    return rejectWith<RecordingResponse>(
      makeError('flash_command_pending', '已有 Flash 协议命令正在等待响应', 'flash', true, {
        kind: pendingCommand.kind
      })
    )
  }
  return new Promise<RecordingResponse>((resolve, reject) => {
    const request = new FlashCommandRequest(kind, sessionGeneration, resolve, reject)
    pendingFlashCommand = request
    startFlashCommandTimeout(request)
    pushDiagnostic('flash_command_enqueued', {
      kind,
      length: command.length,
      generation: sessionGeneration
    })
    writeRecordBytes(command, false)
      .then(() => {
        pushDiagnostic('flash_command_written', {
          kind,
          length: command.length,
          generation: sessionGeneration
        })
      })
      .catch((error) => {
        rejectFlashCommand(
          request,
          makeError('flash_write_failed', 'Flash 协议命令写入失败', 'flash', true, {
            kind,
            error: `${error}`
          })
        )
      })
  })
}

function queryFlashFileCount(): Promise<RecordingResponse> {
  return sendFlashCommand('count', buildFlashGetFileCountCommand())
}

function queryFlashFileInfo(fileId: number): Promise<RecordingResponse> {
  return sendFlashCommand('info', buildFlashGetFileInfoCommand(fileId))
}

function queryFlashDelete(fileId: number): Promise<RecordingResponse> {
  return sendFlashCommand('delete', buildFlashDeleteCommand(fileId))
}

function appendFlashFileInfo(result: Array<any>, info: FlashFileInfo): void {
  result.push({
    fileId: info.fileId,
    fileLength: info.fileLength,
    fileVersion: info.fileVersion,
    blockNum: info.blockNum,
    recordType: info.recordType,
    channels: info.channels,
    sampleRate: info.sampleRate,
    bitRate: info.bitRate,
    recordTime: info.recordTime,
    btAddrHex: info.btAddrHex
  })
}

function loadFlashFileInfos(fileIds: Array<number>, index: Int, results: Array<any>, resolve: (value: Array<any>) => void, reject: (error: any | null) => void): void {
  if (index >= fileIds.length) {
    flashFileListSnapshot.splice(0, flashFileListSnapshot.length)
    results.forEach((item) => {
      flashFileListSnapshot.push(item)
    })
    resolve(results)
    return
  }
  queryFlashFileInfo(fileIds[index])
    .then((infoResponse: RecordingResponse) => {
      if (infoResponse.isFileExist == true && infoResponse.fileInfo != null) {
        appendFlashFileInfo(results, infoResponse.fileInfo!)
      }
      loadFlashFileInfos(fileIds, index + 1, results, resolve, reject)
    })
    .catch((error) => {
      reject(error)
    })
}

function validateFlashDeleteOrder(fileId: number, deleteAfterSuccess: boolean): Promise<RecordingResponse> {
  if (!deleteAfterSuccess) {
    return Promise.resolve(new RecordingResponse())
  }
  return queryFlashFileCount().then((countResponse: RecordingResponse): RecordingResponse => {
    if (countResponse.empty == true || countResponse.fileStartId != fileId) {
      throw makeError('flash_delete_order_violation', '只能安全删除队首 Flash 文件', 'flash', false, {
        requestedFileId: fileId,
        headFileId: countResponse.fileStartId,
        fileCount: countResponse.fileCount
      })
    }
    flashHeadFileId = countResponse.fileStartId
    return countResponse
  })
}

function handleFlashCommandResponse(response: RecordingResponse): void {
  const request = pendingFlashCommand
  if (request == null) {
    pushDiagnostic('unexpected_flash_response', response)
    return
  }
  if (
    (request.kind == 'count' && response.kind != 'flash_count') ||
    (request.kind == 'info' && response.kind != 'flash_info') ||
    (request.kind == 'delete' && response.kind != 'flash_delete')
  ) {
    pushDiagnostic('flash_response_kind_mismatch', {
      expected: request.kind,
      actual: response.kind
    })
    return
  }
  pushDiagnostic('flash_response_received', {
    kind: response.kind,
    generation: request.generation
  })
  completeFlashCommand(request, response)
}

function markRecordingFileWriteError(session: RecordingSession, error: any): void {
  if (session.fileWriteError != null) {
    return
  }
  session.fileWriteError = `${error}`
  emitError(makeError('recording_file_write_failed', '录音文件写入失败', 'recording', true, {
    sessionId: session.sessionId,
    error: session.fileWriteError,
    opusRawPath: session.opusRawPath,
    framesPath: session.framesPath
  }))
}

function deleteFileSilently(path: string): void {
  try {
    const file = new File(path)
    if (file.exists()) {
      file.delete()
    }
  } catch (_error) {}
}

function recordingDecodedOutputPath(session: RecordingSession, format: string): string {
  return `${recordingOutputBasePath()}/${session.sessionId}.${format}`
}

function ensureRecordingDecodeLayout(session: RecordingSession): void {
  if (session.frameCount <= 0) {
    throw makeError('recording_empty', '录音没有收到可解码的音频帧', 'recording', true, recordingSessionSummary(session))
  }
  if (session.channels != 1) {
    throw makeError('opus_decoder_channels_unsupported', '当前 Android decoder 仅支持单声道 OPUS', 'recording', true, recordingSessionSummary(session))
  }
  if (session.frameLen != RECORDING_DECODER_FRAME_LEN || session.variableFrameLen == true) {
    throw makeError(
      'opus_decoder_frame_layout_unsupported',
      '当前 Android decoder 仅支持 4B 帧头 + 80B OPUS payload 的连续帧文件',
      'recording',
      true,
      recordingSessionSummary(session)
    )
  }
  const inputFile = new File(session.framesPath)
  if (!inputFile.exists() || inputFile.length() <= 0) {
    throw makeError('opus_frame_file_missing', 'OPUS 帧诊断文件不存在或为空，无法解码', 'recording', true, recordingSessionSummary(session))
  }
}

function writeAscii(bytes: Array<number>, offset: number, value: string): void {
  const baseOffset = offset.toInt()
  for (let index: Int = 0; index < value.length; index++) {
    const code = value.charCodeAt(index)
    bytes[baseOffset + index] = (code == null ? 0 : code) & 0xff
  }
}

function wavHeaderBytes(pcmSize: number, sampleRate: number, channels: number, bitsPerSample: number): Array<number> {
  const header = new Array<number>()
  for (let index = 0; index < 44; index++) {
    header.push(0)
  }
  const byteRate = sampleRate * channels * Math.floor(bitsPerSample / 8)
  const blockAlign = channels * Math.floor(bitsPerSample / 8)
  writeAscii(header, 0, 'RIFF')
  writeUint32Le(header, 4, 36 + pcmSize)
  writeAscii(header, 8, 'WAVE')
  writeAscii(header, 12, 'fmt ')
  writeUint32Le(header, 16, 16)
  writeUint16Le(header, 20, 1)
  writeUint16Le(header, 22, channels)
  writeUint32Le(header, 24, sampleRate)
  writeUint32Le(header, 28, byteRate)
  writeUint16Le(header, 32, blockAlign)
  writeUint16Le(header, 34, bitsPerSample)
  writeAscii(header, 36, 'data')
  writeUint32Le(header, 40, pcmSize)
  return header
}

function rewriteWavHeader(path: string, pcmSize: number, sampleRate: number, channels: number, bitsPerSample: number): void {
  const file = new File(path)
  const writer = new RandomAccessFile(file, 'rw')
  try {
    writer.seek(0)
    writer.write(numbersToByteArray(wavHeaderBytes(pcmSize, sampleRate, channels, bitsPerSample)))
  } finally {
    writer.close()
  }
}

function readFully(input: FileInputStream, buffer: ByteArray): Int {
  let total: Int = 0
  while (total < buffer.size) {
    const readCount = input.read(buffer, total, buffer.size - total)
    if (readCount <= 0) {
      break
    }
    total += readCount
  }
  return total
}

function opusPayloadFromFrame(frame: ByteArray): ByteArray {
  const payload: ByteArray = new ByteArray(RECORDING_DECODER_FRAME_LEN.toInt())
  const headerLength = RECORDING_FRAME_HEADER_LENGTH.toInt()
  for (let index: Int = 0; index < RECORDING_DECODER_FRAME_LEN; index++) {
    payload[index] = frame[index + headerLength]
  }
  return payload
}

function closeFileInputStream(input: FileInputStream | null): void {
  if (input == null) {
    return
  }
  input.close()
}

function decodeRecordingFramesToWav(session: RecordingSession, outputPath: string): DecodeStats {
  let input: FileInputStream | null = null
  let output: FileOutputStream | null = null
  const decoder = new OpusDecoder()
  let decodedFrames: Int = 0
  let failedFrames: Int = 0
  let pcmBytes: Int = 0
  try {
    if (!decoder.init()) {
      throw makeError('opus_decoder_init_failed', 'OPUS decoder 初始化失败', 'recording', true, recordingSessionSummary(session))
    }
    input = new FileInputStream(new File(session.framesPath))
    output = new FileOutputStream(new File(outputPath), false)
    output.write(numbersToByteArray(wavHeaderBytes(0, RECORDING_SAMPLE_RATE, 1, RECORDING_PCM_BITS_PER_SAMPLE)))

    const frame = new ByteArray(RECORDING_DECODER_FRAME_BYTES.toInt())
    let readCount = readFully(input, frame)
    while (readCount == RECORDING_DECODER_FRAME_BYTES) {
      const pcm = decoder.decode(opusPayloadFromFrame(frame), RECORDING_DECODER_FRAME_SAMPLES.toInt())
      if (pcm != null) {
        output.write(pcm)
        pcmBytes += pcm.size
        decodedFrames += 1
      } else {
        failedFrames += 1
      }
      if (decodedFrames > 0 && decodedFrames % 25 == 0) {
        emitDecodeProgress({
          sessionId: session.sessionId,
          phase: 'decoding',
          progress: Math.floor(decodedFrames * 100 / Math.max(session.frameCount, 1))
        })
      }
      readCount = readFully(input, frame)
    }
    if (readCount > 0) {
      failedFrames += 1
    }
  } catch (error) {
    try {
      decoder.release()
    } catch (_releaseError) {}
    try {
      closeFileInputStream(input)
    } catch (_inputCloseError) {}
    try {
      closeOutputStream(output)
    } catch (_outputCloseError) {}
    deleteFileSilently(outputPath)
    const maybeError = asNativeError(error)
    if (maybeError != null) {
      throw maybeError
    }
    const summary = recordingSessionSummary(session)
    summary['error'] = `${error}`
    throw makeError('opus_decode_failed', 'OPUS 解码失败', 'recording', true, summary)
  }
  try {
    decoder.release()
  } catch (_releaseError) {}
  try {
    closeFileInputStream(input)
  } catch (_inputCloseError) {}
  try {
    closeOutputStream(output)
  } catch (_outputCloseError) {}

  if (decodedFrames <= 0 || pcmBytes <= 0) {
    deleteFileSilently(outputPath)
    const summary = recordingSessionSummary(session)
    summary['decodedFrames'] = decodedFrames
    summary['failedFrames'] = failedFrames
    throw makeError('opus_decode_empty_output', 'OPUS 解码没有生成有效 PCM 数据', 'recording', true, summary)
  }
  const totalDecodedAttempts = decodedFrames + failedFrames
  if (totalDecodedAttempts > 0 && failedFrames / totalDecodedAttempts > RECORDING_DECODE_FAILURE_THRESHOLD) {
    deleteFileSilently(outputPath)
    const summary = recordingSessionSummary(session)
    summary['decodedFrames'] = decodedFrames
    summary['failedFrames'] = failedFrames
    summary['failureThreshold'] = RECORDING_DECODE_FAILURE_THRESHOLD
    throw makeError('opus_decode_corruption_threshold', 'OPUS 解码失败帧比例过高', 'recording', true, summary)
  }
  rewriteWavHeader(outputPath, pcmBytes, RECORDING_SAMPLE_RATE, 1, RECORDING_PCM_BITS_PER_SAMPLE)
  return new DecodeStats(decodedFrames, failedFrames, pcmBytes)
}

function decodeRecordingFramesToMp3(session: RecordingSession, outputPath: string): DecodeStats {
  const decoder = new OpusDecoder()
  try {
    decoder.decodeOpusToMp3(session.framesPath, outputPath)
  } catch (error) {
    try {
      decoder.release()
    } catch (_releaseError) {}
    deleteFileSilently(outputPath)
    const summary = recordingSessionSummary(session)
    summary['error'] = `${error}`
    throw makeError('opus_decode_failed', 'OPUS MP3 解码失败', 'recording', true, summary)
  }
  try {
    decoder.release()
  } catch (_releaseError) {}
  return new DecodeStats(session.frameCount, 0, 0)
}

function decodeRecordingSession(session: RecordingSession, format: string): RecordingResult {
  ensureRecordingDecodeLayout(session)
  const outputPath = recordingDecodedOutputPath(session, format)
  deleteFileSilently(outputPath)
  emitDecodeProgress({
    sessionId: session.sessionId,
    phase: 'decoding',
    progress: 0
  })
  const decodeStats = format == 'mp3'
    ? decodeRecordingFramesToMp3(session, outputPath)
    : decodeRecordingFramesToWav(session, outputPath)

  const outputFile = new File(outputPath)
  const minimumSize = format == 'wav' ? 44 : 1
  if (!outputFile.exists() || outputFile.length() <= minimumSize) {
    deleteFileSilently(outputPath)
    const summary = recordingSessionSummary(session)
    summary['format'] = format
    summary['outputPath'] = outputPath
    summary['minimumSize'] = minimumSize
    throw makeError('opus_decode_empty_output', 'OPUS 解码没有生成有效音频文件', 'recording', true, summary)
  }
  emitDecodeProgress({
    sessionId: session.sessionId,
    phase: 'finalizing',
    progress: 100
  })
  const result = new RecordingResult(outputPath, format)
  result.durationMs = session.durationMs
  result.sampleRate = session.sampleRate
  result.channels = session.channels
  result.frameCount = session.frameCount
  result.frameLen = session.frameLen
  result.decodedFrames = decodeStats.decodedFrames
  result.failedFrames = decodeStats.failedFrames
  result.pcmBytes = decodeStats.pcmBytes
  result.lostFrames = session.lostFrames
  result.outOfOrderFrames = session.outOfOrderFrames
  result.badFrames = session.badFrames
  result.size = outputFile.length()
  result.source = session.source
  result.fileId = session.fileId
  result.opusRawPath = session.opusRawPath
  result.framesPath = session.framesPath
  return result
}

function updateRecordingIndexStats(session: RecordingSession, dataIndex: number): void {
  if (session.lastIndex == null) {
    session.lastIndex = dataIndex
    return
  }
  const expected = ((session.lastIndex as number) + 1) & 0xffff
  if (dataIndex != expected) {
    const forwardGap = (dataIndex - expected + 65536) % 65536
    if (forwardGap > 0 && forwardGap < 32768) {
      session.lostFrames += forwardGap
    } else {
      session.outOfOrderFrames += 1
    }
  }
  session.lastIndex = dataIndex
}

function appendRecordingFramesToSession(session: RecordingSession, response: RecordingResponse, diagnosticEvent: string): void {
  const payloadBatch = new Array<number>()
  const rawBatch = new Array<number>()
  const frames = response.frames
  for (let index = 0; index < frames.length; index++) {
    const frame = frames[index]
    updateRecordingIndexStats(session, frame.dataIndex)
    session.frameCount += 1
    if (session.frameLen == 0) {
      session.frameLen = frame.frameLen
    } else if (session.frameLen != frame.frameLen) {
      session.variableFrameLen = true
    }
    session.durationMs += frame.frameTimeMs
    session.channels = frame.channels
    session.bitrate = frame.bitrate
    const payload = frame.payload
    const rawFrame = frame.rawFrame
    for (let payloadIndex = 0; payloadIndex < payload.length; payloadIndex++) {
      payloadBatch.push(payload[payloadIndex] & 0xff)
    }
    for (let rawIndex = 0; rawIndex < rawFrame.length; rawIndex++) {
      rawBatch.push(rawFrame[rawIndex] & 0xff)
    }
    session.opusPayloadBytes += payload.length
    session.framedBytes += rawFrame.length
  }
  session.badFrames += response.badFrames
  if (payloadBatch.length > 0 || rawBatch.length > 0) {
    try {
      appendBytesToOutputStream(session.opusRawStream, payloadBatch)
      appendBytesToOutputStream(session.framesStream, rawBatch)
    } catch (error) {
      markRecordingFileWriteError(session, error)
    }
  }

  // 实时音频流解码 - 批量累积帧后解码
  if (session.enableRealtimeStream) {
    const decoder = session.enableRealtimeStreamr
    const outputStream = session.realtimeOutputStream

    if (decoder != null && outputStream != null) {
      // 将新帧添加到待处理队列
      for (let index = 0; index < frames.length; index++) {
        const frame = frames[index]
        session.realtimePendingFrames.push(numbersToByteArray(frame.rawFrame))
      }

      // 当累积帧数达到阈值时，批量解码
      if (session.realtimePendingFrames.length >= session.realtimeBatchFrames) {
        const framesToDecode = session.realtimePendingFrames.length
        let batchDecodedFrames: Int = 0
        let batchFailedFrames: Int = 0
        const waveformSamples = new Array<number>()
        const batchPcmChunks = new Array<ByteArray>()

        for (let index = 0; index < framesToDecode; index++) {
          const rawFrame = session.realtimePendingFrames[index]
          try {
            const payload = opusPayloadFromFrame(rawFrame)
            const pcm = decoder.decode(payload, RECORDING_DECODER_FRAME_SAMPLES.toInt())

            if (pcm != null) {
              outputStream.write(pcm)
              session.realtimePcmBytes += pcm.size
              batchDecodedFrames += 1

              // 累积 PCM（单帧回调和批次回调都需要）
              if (realtimePcmDataCallbacks.size > 0) {
                batchPcmChunks.push(pcm)
              }

              // 提取波形数据（每隔 N 个样本取一个，用于波形显示）
              const sampleStep = 64
              for (let i: Int = 0; i < pcm.size; i += 2) {
                if (i % (sampleStep * 2) == 0) {
                  const sample = (pcm[i] & 0xff) | ((pcm[i + 1] & 0xff) << 8)
                  const signedSample = sample > 32767 ? sample - 65536 : sample
                  waveformSamples.push(signedSample)
                }
              }
            } else {
              batchFailedFrames += 1
            }
          } catch (error) {
            batchFailedFrames += 1
            pushDiagnostic('realtime_decode_frame_error', {
              sessionId: session.sessionId,
              frameIndex: session.enableRealtimeStreamdFrames + batchDecodedFrames,
              error: `${error}`
            })
          }
        }

        session.enableRealtimeStreamdFrames += batchDecodedFrames
        session.realtimeFailedFrames += batchFailedFrames

        // 清空已处理的帧
        session.realtimePendingFrames.splice(0, framesToDecode)

        // 上报解码进度
        emitDecodeProgress({
          sessionId: session.sessionId,
          phase: 'decoding',
          progress: Math.floor(session.enableRealtimeStreamdFrames * 100 / Math.max(session.frameCount, 1))
        })

        // 批次结束后回调 PCM 数据
        if (batchPcmChunks.length > 0) {
          let totalBytes: Int = 0
          for (let c: Int = 0; c < batchPcmChunks.length; c++) {
            totalBytes += batchPcmChunks[c].size
          }
          const merged = new ByteArray(totalBytes)
          let offset: Int = 0
          for (let c: Int = 0; c < batchPcmChunks.length; c++) {
            const chunk = batchPcmChunks[c]
            for (let b: Int = 0; b < chunk.size; b++) {
              merged[offset] = chunk[b]
              offset += 1
            }
          }
          const batchBase64 = android.util.Base64.encodeToString(merged, android.util.Base64.NO_WRAP)
          const batchEvent = {
            sessionId: session.sessionId,
            pcmBase64: batchBase64,
            byteLength: totalBytes,
            sampleRate: RECORDING_SAMPLE_RATE,
            channels: 1,
            bitsPerSample: RECORDING_PCM_BITS_PER_SAMPLE,
            durationMs: Math.floor(totalBytes / 2 * 1000 / RECORDING_SAMPLE_RATE)
          }
          // 单帧回调：每帧单独 base64 发出
          const frameEvents = new Array<any>()
          for (let c: Int = 0; c < batchPcmChunks.length; c++) {
            const frameBase64 = android.util.Base64.encodeToString(batchPcmChunks[c], android.util.Base64.NO_WRAP)
            frameEvents.push({
              sessionId: session.sessionId,
              pcmBase64: frameBase64,
              byteLength: batchPcmChunks[c].size,
              sampleRate: RECORDING_SAMPLE_RATE,
              channels: 1,
              bitsPerSample: RECORDING_PCM_BITS_PER_SAMPLE,
              durationMs: 40
            })
          }
          realtimePcmDataCallbacks.forEach((perFrame: boolean, callback: NativeProgressCallback) => {
            if (perFrame) {
              for (let f: Int = 0; f < frameEvents.length; f++) {
                callback(frameEvents[f])
              }
            } else {
              callback(batchEvent)
            }
          })
        }

        // 发送波形数据
        if (waveformSamples.length > 0) {
          emitWaveformData({
            sessionId: session.sessionId,
            samples: waveformSamples,
            sampleCount: waveformSamples.length
          })
        }

        pushDiagnostic('realtime_decode_batch_processed', {
          sessionId: session.sessionId,
          batchSize: framesToDecode,
          decodedFrames: batchDecodedFrames,
          failedFrames: batchFailedFrames,
          totalDecoded: session.enableRealtimeStreamdFrames,
          totalFailed: session.realtimeFailedFrames,
          pendingFrames: session.realtimePendingFrames.length,
          waveformSamples: waveformSamples.length
        })
      }
    }
  }

  pushDiagnostic(diagnosticEvent, {
    sessionId: session.sessionId,
    source: session.source,
    frameCount: frames.length,
    badFrames: response.badFrames,
    totalFrames: session.frameCount,
    durationMs: session.durationMs
  })
  emitRecordingProgress(session)
}

function handleRecordingFrames(response: RecordingResponse): void {
  const session = recordingSession
  if (session == null) {
    pushDiagnostic('recording_frames_without_session', {
      frameCount: response.frames.length,
      badFrames: response.badFrames
    })
    return
  }
  appendRecordingFramesToSession(session, response, 'recording_frames_received')
}

function startFlashDownloadTimeout(active: FlashDownloadSession): void {
  clearFlashDownloadTimeout()
  flashDownloadTimeoutId = setTimeout(() => {
    if (flashSession != active || active.completed == true) {
      return
    }
    try {
      writeRecordBytes(buildFlashStopUploadCommand(), true)
    } catch (_error) {}
    rejectFlashSession(
      active,
      makeError('flash_download_timeout', 'Flash 文件数据帧超时', 'flash', true, {
        fileId: active.fileInfo.fileId,
        timeoutMs: FLASH_DOWNLOAD_FRAME_TIMEOUT_MS,
        downloadedBytes: active.session.downloadedBytes
      })
    )
  }, FLASH_DOWNLOAD_FRAME_TIMEOUT_MS)
}

function flashProgressOf(session: RecordingSession): number {
  const expected = session.expectedBytes
  if (expected <= 0) {
    return 0
  }
  const value = Math.floor(session.downloadedBytes * 100 / expected)
  if (value < 0) return 0
  if (value > 100) return 100
  return value
}

function finalizeFlashDownloadSession(active: FlashDownloadSession | null): void {
  if (active == null || active.completed == true) {
    return
  }
  active.completed = true
  clearFlashDownloadTimeout()
  if (flashSession == active) {
    flashSession = null
  }
  const session = active.session
  session.stoppedAt = nowIso()
  session.progress = 100
  closeRecordingSessionStreams(session)
  emitRecordingProgress(session, true)
  try {
    const result = decodeRecordingSession(session, active.format)
    result.source = 'flash'
    result.fileId = active.fileInfo.fileId
    result.deleteAfterSuccess = active.deleteAfterSuccess
    pushDiagnostic('flash_download_decoded', {
      fileId: active.fileInfo.fileId,
      filePath: result.filePath,
      format: active.format,
      size: result.size
    })
    if (active.deleteAfterSuccess == true) {
      queryFlashDelete(active.fileInfo.fileId)
        .then((deleteResult) => {
          const deleteResponse = deleteResult as RecordingResponse
          if (deleteResponse.status != FLASH_DELETE_STATUS_SUCCESS) {
            const details = {
              fileId: active.fileInfo.fileId,
              status: deleteResponse.status,
              currentHeadFileId: deleteResponse.fileId
            }
            const error = makeError('flash_delete_failed', 'Flash 文件下载成功，但删除失败', 'flash', true, details)
            emitError(error)
            active.reject(error)
            return
          }
          result.deleted = true
          result.nextFileId = deleteResponse.fileId
          active.resolve(result)
        })
        .catch((error) => {
          active.reject(error)
        })
      return
    }
    active.resolve(result)
  } catch (error) {
    const maybeError = asNativeError(error)
    if (maybeError != null) {
      emitError(maybeError)
      active.reject(maybeError)
      return
    }
    const nativeError = makeError('flash_decode_failed', 'Flash 文件解码失败', 'flash', true, {
      fileId: active.fileInfo.fileId,
      error: `${error}`,
      summary: recordingSessionSummary(session)
    })
    emitError(nativeError)
    active.reject(nativeError)
  }
}

function handleFlashDownloadResponse(response: RecordingResponse): void {
  const active = flashSession
  if (active == null) {
    pushDiagnostic('unexpected_flash_download_response', response)
    return
  }
  if (response.readError == true || response.fileMissing == true) {
    rejectFlashSession(
      active,
      makeError('flash_download_failed', 'Flash 文件读取失败', 'flash', true, {
        fileId: active.fileInfo.fileId,
        returnLength: response.returnLength
      })
    )
    return
  }

  const declaredBytes = response.returnLength
  const data = response.fileData
  const dataLength = declaredBytes < data.length ? declaredBytes : data.length
  const frameBytes = byteSlice(data, 0, dataLength)
  const split = splitRecordingFrames(frameBytes)
  appendRecordingFramesToSession(active.session, split, 'flash_frames_received')
  active.session.downloadedBytes = response.startAddress + dataLength
  active.session.progress = flashProgressOf(active.session)
  pushDiagnostic('flash_download_chunk', {
    fileId: active.fileInfo.fileId,
    startAddress: response.startAddress,
    returnLength: response.returnLength,
    dataCapacity: response.dataCapacity,
    downloadedBytes: active.session.downloadedBytes,
    progress: active.session.progress,
    completed: response.completed
  })
  emitRecordingProgress(active.session, true)

  const expectedBytes = active.session.expectedBytes
  if (response.completed == true || (expectedBytes > 0 && active.session.downloadedBytes >= expectedBytes)) {
    finalizeFlashDownloadSession(active)
    return
  }
  startFlashDownloadTimeout(active)
}

function handleRecordingStartResponse(response: RecordingResponse): void {
  const request = pendingRecordingCommand
  if (request == null || request.kind != 'start') {
    pushDiagnostic('unexpected_recording_start_response', response)
    if (response.startReason == 0) {
      writeRecordBytes(buildRecordingCommand(RECORDING_COMMAND_STOP, [1]), false)
        .catch((writeError) => {
          pushDiagnostic('recording_late_start_cleanup_failed', { error: `${writeError}` })
        })
    }
    return
  }
  if (response.startReason != 0) {
    rejectRecordingCommand(
      request,
      makeError('recording_start_rejected', '设备拒绝启动录音', 'recording', true, response)
    )
    return
  }
  try {
    const session = createRecordingSession(request.scene, response)

    // 检查是否启用实时音频流
    const enableRealtimeStream = optionBoolean(request.options, 'enableRealtimeStream', false)
    const format = requestedRecordingFormatOf(request.options)

    if (enableRealtimeStream) {
      if (format != 'wav') {
        throw makeError('realtime_decode_format_unsupported', '实时解码目前仅支持 WAV 格式', 'recording', true, {
          requestedFormat: format
        })
      }
      session.enableRealtimeStream = true
      session.realtimeFormat = format
      session.realtimeBatchFrames = optionNumber(request.options, 'realtimeBatchFrames', REALTIME_DECODE_BATCH_FRAMES_DEFAULT)
      initRealtimeDecoder(session)
    }

    recordingSession = session
    pushDiagnostic('recording_session_started', recordingSessionSummary(session))
    emitRecordingProgress(session, true)
    completeRecordingCommand(request, {
      sessionId: session.sessionId,
      scene: session.scene,
      state: 'recording',
      recordChannel: response.recordChannel,
      packetLength: response.packetLength,
      sampleRate: session.sampleRate,
      channels: session.channels,
      enableRealtimeStream: session.enableRealtimeStream,
      decodeMode: session.enableRealtimeStream ? 'realtime' : 'batch'
    })
  } catch (error) {
    writeRecordBytes(buildRecordingCommand(RECORDING_COMMAND_STOP, [1]), false)
      .catch((writeError) => {
        pushDiagnostic('recording_cleanup_stop_failed', { error: `${writeError}` })
      })
    rejectRecordingCommand(
      request,
      makeError('recording_file_open_failed', '录音文件创建失败，已尝试停止设备录音', 'recording', true, {
        error: `${error}`
      })
    )
  }
}

function handleRecordingStopResponse(response: RecordingResponse): void {
  const request = pendingRecordingCommand
  const session = recordingSession
  if (request == null || request.kind != 'stop') {
    pushDiagnostic('unexpected_recording_stop_response', response)
    if (session != null) {
      session.stoppedAt = nowIso()
      closeRecordingSessionStreams(session)
      emitRecordingProgress(session, true)
      recordingSession = null
    }
    return
  }
  if (session == null) {
    rejectRecordingCommand(
      request,
      makeError('recording_session_missing', '录音停止响应已收到，但本地 session 不存在', 'recording', true, response)
    )
    return
  }
  session.stoppedAt = nowIso()
  closeRecordingSessionStreams(session)
  emitRecordingProgress(session, true)
  recordingSession = null

  const summary = recordingSessionSummary(session)
  summary['stopReason'] = response.stopReason
  summary['stopReasonScene'] = response.stopReasonScene
  pushDiagnostic('recording_session_stopped', summary)

  if (session.fileWriteError != null) {
    rejectRecordingCommand(
      request,
      makeError('recording_file_write_failed', '录音文件写入失败，无法继续解码', 'recording', true, summary)
    )
    return
  }

  try {
    let result: RecordingResult
    if (session.enableRealtimeStream) {
      // 使用实时音频流解码结果
      result = finalizeRealtimeDecoding(session)
      pushDiagnostic('realtime_decode_completed', {
        sessionId: session.sessionId,
        format: session.realtimeFormat,
        filePath: result.filePath,
        size: result.size,
        decodedFrames: session.enableRealtimeStreamdFrames,
        failedFrames: session.realtimeFailedFrames
      })
    } else {
      // 使用批量解码
      result = decodeRecordingSession(session, request.format)
      pushDiagnostic('recording_decode_completed', {
        sessionId: session.sessionId,
        format: request.format,
        filePath: result.filePath,
        size: result.size
      })
    }
    completeRecordingCommand(request, result)
  } catch (error) {
    const maybeError = asNativeError(error)
    if (maybeError != null) {
      rejectRecordingCommand(request, maybeError)
      return
    }
    summary['requestedFormat'] = request.format
    summary['error'] = `${error}`
    rejectRecordingCommand(
      request,
      makeError('opus_decode_failed', 'OPUS 解码失败', 'recording', true, summary)
    )
  }
}

function handleRecordNotify(bytes: Array<number>, generation: number): void {
  if (generation != sessionGeneration) {
    pushDiagnostic('stale_record_notify_ignored', { generation, current: sessionGeneration })
    return
  }
  pushDiagnostic('record_notify', {
    length: bytes.length,
    generation
  })
  try {
    const response = parseRecordingResponse(bytes)
    if (response.kind == 'start') {
      handleRecordingStartResponse(response)
      return
    }
    if (response.kind == 'stop') {
      handleRecordingStopResponse(response)
      return
    }
    if (response.kind == 'flash_count' || response.kind == 'flash_info' || response.kind == 'flash_delete') {
      handleFlashCommandResponse(response)
      return
    }
    if (response.kind == 'flash_download') {
      handleFlashDownloadResponse(response)
      return
    }
    handleRecordingFrames(response)
  } catch (error) {
    const maybeError = asNativeError(error)
    let nativeError: OleapBleNativeError
    if (maybeError != null) {
      nativeError = maybeError
    } else {
      nativeError = makeError('recording_protocol_error', '录音协议解析失败', 'recording', true, {
        error: `${error}`,
        length: bytes.length,
        head: bytesToHex(bytes)
      })
    }
    emitError(nativeError)
  }
}

function descriptorForNotify(characteristic: BluetoothGattCharacteristic | null): BluetoothGattDescriptor | null {
  if (characteristic == null) {
    return null
  }
  return characteristic.getDescriptor(UUID.fromString(CLIENT_CHARACTERISTIC_CONFIG_UUID))
}

function failNotificationEnable(gatt: BluetoothGatt, code: string, details: any | null = null): void {
  const error = makeError(code, '开启 Android BLE notify 失败', 'connection', true, details)
  closeGatt(true)
  rejectPendingConnect(error)
}

function finishConnectionReady(gatt: BluetoothGatt): void {
  const device = gatt.getDevice()
  connectedDeviceId = pendingDeviceId ?? (device == null ? '' : deviceAddressOf(device))
  connectedDeviceName = pendingDeviceName ?? (device == null ? null : deviceNameOf(device))
  const deviceInfo = {
    deviceId: connectedDeviceId,
    name: connectedDeviceName ?? 'Oleap Device',
    rssi: 0,
    manufacturerDataHex: ''
  }
  connecting = false
  enablingNotifications = false
  clearServiceDiscoveryRetryTimeout()
  pushDiagnostic('channels_ready', channelReadySnapshot())
  emitConnectionChanged(true, deviceInfo)
  resolvePendingConnect(deviceInfo)
}

function writeNextNotifyDescriptor(gatt: BluetoothGatt): void {
  const descriptor = pendingNotifyDescriptors.shift()
  if (descriptor == null) {
    activeNotifyDescriptor = null
    finishConnectionReady(gatt)
    return
  }
  activeNotifyDescriptor = descriptor
  try {
    descriptor.setValue(BluetoothGattDescriptor.ENABLE_NOTIFICATION_VALUE)
    const started = gatt.writeDescriptor(descriptor)
    if (!started) {
      failNotificationEnable(gatt, 'notify_descriptor_write_rejected', {
        uuid: descriptor.getUuid().toString()
      })
    }
  } catch (error) {
    failNotificationEnable(gatt, 'notify_descriptor_write_failed', {
      error: `${error}`,
      uuid: descriptor.getUuid().toString()
    })
  }
}

function enableRequiredNotifications(gatt: BluetoothGatt): void {
  enablingNotifications = true
  notifyEnableGeneration = sessionGeneration
  pendingNotifyDescriptors.splice(0, pendingNotifyDescriptors.length)

  const communicationDescriptor = descriptorForNotify(communicationNotifyChar)
  const recordDescriptor = descriptorForNotify(recordNotifyChar)
  if (communicationDescriptor == null || recordDescriptor == null) {
    failNotificationEnable(gatt, 'notify_descriptor_missing', {
      communicationDescriptor: communicationDescriptor != null,
      recordDescriptor: recordDescriptor != null
    })
    return
  }

  try {
    const communicationEnabled = gatt.setCharacteristicNotification(communicationNotifyChar, true)
    const recordEnabled = gatt.setCharacteristicNotification(recordNotifyChar, true)
    if (!communicationEnabled || !recordEnabled) {
      failNotificationEnable(gatt, 'set_characteristic_notification_failed', {
        communicationEnabled,
        recordEnabled
      })
      return
    }
  } catch (error) {
    failNotificationEnable(gatt, 'set_characteristic_notification_exception', { error: `${error}` })
    return
  }

  pendingNotifyDescriptors.push(communicationDescriptor)
  pendingNotifyDescriptors.push(recordDescriptor)
  pushDiagnostic('notify_enable_start', {
    descriptorCount: pendingNotifyDescriptors.length,
    generation: sessionGeneration
  })
  writeNextNotifyDescriptor(gatt)
}

function characteristicForChannel(channel: string): BluetoothGattCharacteristic | null {
  if (channel == 'communication') {
    return communicationWriteChar
  }
  if (channel == 'record') {
    return recordWriteChar
  }
  return null
}

function processNextWrite(): void {
  if (activeWriteRequest != null) {
    return
  }
  const request = writeQueue.shift()
  if (request == null) {
    return
  }
  const gatt = connectedGatt
  if (gatt == null || request.generation != sessionGeneration) {
    request.reject(
      makeError('stale_or_disconnected_write', 'BLE session 已失效，写入被拒绝', 'connection', true, {
        requestGeneration: request.generation,
        currentGeneration: sessionGeneration
      })
    )
    processNextWrite()
    return
  }
  const characteristic = characteristicForChannel(request.channel)
  if (characteristic == null) {
    request.reject(
      makeError('write_channel_not_ready', 'BLE 写入通道未就绪', 'connection', true, {
        channel: request.channel
      })
    )
    processNextWrite()
    return
  }

  activeWriteRequest = request
  try {
    request.gatt = gatt
    request.characteristicUuid = characteristic.getUuid().toString().toLowerCase()
    characteristic.setWriteType(
      request.withoutResponse
        ? BluetoothGattCharacteristic.WRITE_TYPE_NO_RESPONSE
        : BluetoothGattCharacteristic.WRITE_TYPE_DEFAULT
    )
    characteristic.setValue(numbersToByteArray(request.value))
    const started = gatt.writeCharacteristic(characteristic)
    if (!started) {
      activeWriteRequest = null
      request.reject(
        makeError('write_rejected', 'Android BLE 写入启动失败', 'connection', true, {
          channel: request.channel
        })
      )
      processNextWrite()
      return
    }

    pushDiagnostic('characteristic_write_started', {
      channel: request.channel,
      uuid: request.characteristicUuid,
      withoutResponse: request.withoutResponse,
      generation: request.generation
    })
    writeTimeoutId = setTimeout(() => {
      const timedOut = activeWriteRequest
      activeWriteRequest = null
      clearWriteTimeout()
      if (timedOut != null) {
        timedOut.reject(
          makeError('write_timeout', 'Android BLE 写入回调超时', 'connection', true, {
            channel: timedOut.channel,
            generation: timedOut.generation,
            timeoutMs: DEFAULT_WRITE_TIMEOUT_MS
          })
        )
      }
      processNextWrite()
    }, DEFAULT_WRITE_TIMEOUT_MS)
  } catch (error) {
    activeWriteRequest = null
    request.reject(
      makeError('write_failed', 'Android BLE 写入异常', 'connection', true, {
        channel: request.channel,
        error: `${error}`
      })
    )
    processNextWrite()
  }
}

function writeByChannel(channel: string, value: Array<number>, withoutResponse: boolean = false): Promise<void> {
  const initError = ensureInitialized()
  if (initError != null) {
    return rejectWith<void>(initError)
  }
  if (connectedGatt == null || connectedDeviceId == null) {
    return rejectWith<void>(
      makeError('device_not_connected', '尚未连接 Oleap 设备', 'connection', true)
    )
  }
  if (characteristicForChannel(channel) == null) {
    return rejectWith<void>(
      makeError('write_channel_not_ready', 'BLE 写入通道未就绪', 'connection', true, { channel })
    )
  }

  return new Promise<void>((resolve, reject) => {
    writeQueue.push(new WriteRequest(
      channel,
      value,
      withoutResponse,
      sessionGeneration,
      () => {
        resolve()
      },
      reject
    ))
    pushDiagnostic('write_queued', {
      channel,
      length: value.length,
      withoutResponse,
      queueDepth: writeQueue.length,
      generation: sessionGeneration
    })
    processNextWrite()
  })
}

function writeCommunicationBytes(value: Array<number>, withoutResponse: boolean = false): Promise<void> {
  return writeByChannel('communication', value, withoutResponse)
}

function writeRecordBytes(value: Array<number>, withoutResponse: boolean = false): Promise<void> {
  return writeByChannel('record', value, withoutResponse)
}

class OleapGattCallback extends BluetoothGattCallback {
  generation: number

  constructor(generation: number) {
    super()
    this.generation = generation
  }

  isCurrentGatt(gatt: BluetoothGatt, event: string): boolean {
    if (this.generation != sessionGeneration || connectedGatt == null || gatt != connectedGatt) {
      pushDiagnostic('stale_gatt_callback_ignored', {
        event,
        callbackGeneration: this.generation,
        currentGeneration: sessionGeneration
      })
      return false
    }
    return true
  }

  @UTSJS.keepAlive
  override onConnectionStateChange(gatt: BluetoothGatt, status: Int, newState: Int): void {
    if (!this.isCurrentGatt(gatt, 'connection_state')) {
      return
    }
    const device = gatt.getDevice()
    const deviceId = device == null ? '' : deviceAddressOf(device)
    pushDiagnostic('gatt_connection_state', {
      status,
      newState,
      deviceId,
      generation: sessionGeneration
    })

    if (newState == BluetoothProfile.STATE_CONNECTED && status == BluetoothGatt.GATT_SUCCESS) {
      connectedGatt = gatt
      pendingDeviceId = deviceId
      pendingDeviceName = device == null ? null : deviceNameOf(device)
      currentMtu = DEFAULT_ANDROID_ATT_MTU
      serviceDiscoveryAttempt = 0
      requestHighConnectionPriority(gatt)
      requestPreferredMtuAndDiscover(gatt)
      return
    }

    if (newState == BluetoothProfile.STATE_DISCONNECTED) {
      const wasConnecting = connecting
      closeGatt(true)
      emitConnectionChanged(false, null)
      if (wasConnecting) {
        rejectPendingConnect(
          makeError(
            status == BluetoothGatt.GATT_SUCCESS ? 'connect_disconnected' : 'connect_gatt_failed',
            'Android GATT 连接断开',
            'connection',
            true,
            { status, deviceId }
          )
        )
      }
    }
  }

  @UTSJS.keepAlive
  override onServicesDiscovered(gatt: BluetoothGatt, status: Int): void {
    if (!this.isCurrentGatt(gatt, 'services_discovered')) {
      return
    }
    handleServicesDiscovered(gatt, status)
  }

  @UTSJS.keepAlive
  override onMtuChanged(gatt: BluetoothGatt, mtu: Int, status: Int): void {
    if (!this.isCurrentGatt(gatt, 'mtu_changed')) {
      return
    }
    if (status == BluetoothGatt.GATT_SUCCESS && mtu > 0) {
      currentMtu = mtu
    }
    pushDiagnostic('mtu_changed', {
      status,
      mtu,
      currentMtu,
      generation: sessionGeneration
    })
    beginServiceDiscoveryAfterMtu(gatt, status == BluetoothGatt.GATT_SUCCESS ? 'mtu_changed' : 'mtu_failed')
  }

  @UTSJS.keepAlive
  override onDescriptorWrite(gatt: BluetoothGatt, descriptor: BluetoothGattDescriptor, status: Int): void {
    if (!this.isCurrentGatt(gatt, 'descriptor_write')) {
      return
    }
    pushDiagnostic('descriptor_write', {
      uuid: descriptor.getUuid().toString(),
      status,
      generation: sessionGeneration
    })
    if (
      activeNotifyDescriptor == null ||
      notifyEnableGeneration != this.generation ||
      !sameUuid(descriptor.getUuid(), CLIENT_CHARACTERISTIC_CONFIG_UUID)
    ) {
      return
    }
    activeNotifyDescriptor = null
    if (status != BluetoothGatt.GATT_SUCCESS) {
      failNotificationEnable(gatt, 'notify_descriptor_write_failed_status', {
        status,
        uuid: descriptor.getUuid().toString()
      })
      return
    }
    writeNextNotifyDescriptor(gatt)
  }

  @UTSJS.keepAlive
  override onCharacteristicChanged(gatt: BluetoothGatt, characteristic: BluetoothGattCharacteristic): void {
    if (!this.isCurrentGatt(gatt, 'characteristic_changed')) {
      return
    }
    this.dispatchCharacteristicChanged(characteristic, byteArrayToNumbers(characteristic.value), this.generation)
  }

  @UTSJS.keepAlive
  override onCharacteristicChanged(gatt: BluetoothGatt, characteristic: BluetoothGattCharacteristic, value: ByteArray): void {
    if (!this.isCurrentGatt(gatt, 'characteristic_changed_value')) {
      return
    }
    this.dispatchCharacteristicChanged(characteristic, byteArrayToNumbers(value), this.generation)
  }

  dispatchCharacteristicChanged(characteristic: BluetoothGattCharacteristic, bytes: Array<number>, generation: number): void {
    if (sameUuid(characteristic.getUuid(), COMMUNICATION_NOTIFY_UUID)) {
      handleCommunicationNotify(bytes, generation)
      return
    }
    if (sameUuid(characteristic.getUuid(), RECORD_NOTIFY_UUID)) {
      handleRecordNotify(bytes, generation)
      return
    }
    pushDiagnostic('unknown_notify_ignored', {
      uuid: characteristic.getUuid().toString(),
      length: bytes.length,
      generation
    })
  }

  @UTSJS.keepAlive
  override onCharacteristicWrite(gatt: BluetoothGatt, characteristic: BluetoothGattCharacteristic, status: Int): void {
    const request = activeWriteRequest
    if (request == null) {
      pushDiagnostic('unexpected_characteristic_write', {
        uuid: characteristic.getUuid().toString(),
        status,
        generation: sessionGeneration
      })
      return
    }
    if (
      !this.isCurrentGatt(gatt, 'characteristic_write') ||
      request.gatt != gatt ||
      request.characteristicUuid != characteristic.getUuid().toString().toLowerCase()
    ) {
      pushDiagnostic('stale_characteristic_write_ignored', {
        uuid: characteristic.getUuid().toString(),
        status,
        requestGeneration: request.generation,
        callbackGeneration: this.generation,
        currentGeneration: sessionGeneration
      })
      return
    }
    clearWriteTimeout()
    activeWriteRequest = null
    pushDiagnostic('characteristic_write', {
      channel: request.channel,
      uuid: characteristic.getUuid().toString(),
      status,
      generation: this.generation
    })
    if (request.generation != sessionGeneration) {
      request.reject(
        makeError('stale_write_result', '旧 BLE session 的写入结果已忽略', 'connection', true, {
          requestGeneration: request.generation,
          currentGeneration: sessionGeneration
        })
      )
    } else if (status == BluetoothGatt.GATT_SUCCESS) {
      request.resolve()
    } else {
      request.reject(
        makeError('write_failed_status', 'Android BLE 写入失败', 'connection', true, {
          channel: request.channel,
          status
        })
      )
    }
    processNextWrite()
  }
}

export function init(options: any | null = null): Promise<void> {
  initialized = true
  pushDiagnostic('sdk_init', {
    version: SDK_VERSION,
    platform: 'android',
    options
  })
  return Promise.resolve()
}

export function requestPermissions(): Promise<any> {
  const initError = ensureInitialized()
  if (initError != null) {
    return rejectWith<any>(initError)
  }
  if (isAndroid12TargetTooLow()) {
    return rejectWith<any>(
      makeError(
        'target_sdk_too_low',
        '当前自定义基座 targetSdkVersion 低于 31，Android 12+ 无法授予 BLUETOOTH_SCAN 权限，请重新打包基座',
        'permission',
        false,
        {
          androidSdk: Build.VERSION.SDK_INT,
          targetSdk: appTargetSdkVersion()
        }
      )
    )
  }
  const activity = UTSAndroid.getUniActivity()
  if (activity == null) {
    return rejectWith<any>(
      makeError('activity_missing', '无法获取当前 Activity', 'permission', true)
    )
  }
  const permissions = requiredPermissions()
  return new Promise<any>((resolve, reject) => {
    UTSAndroid.requestSystemPermission(
      activity,
      permissions,
      (allRight: boolean, grantedList: Array<string>) => {
        const result = permissionResult()
        pushDiagnostic('permission_result', {
          allRight,
          grantedList,
          result
        })
        resolve(result)
      },
      (doNotAskAgain: boolean, grantedList: Array<string>) => {
        const error = makeError(
          doNotAskAgain ? 'permission_permanently_denied' : 'permission_denied',
          '蓝牙权限未授予',
          'permission',
          !doNotAskAgain,
          { grantedList }
        )
        emitError(error)
        reject(error)
      }
    )
  })
}

export function getBluetoothState(): Promise<any> {
  const initError = ensureInitialized()
  if (initError != null) {
    return rejectWith<any>(initError)
  }
  const adapter = getBluetoothAdapter()
  const state = {
    supported: adapter != null,
    enabled: adapter != null && adapter.isEnabled(),
    permissionGranted: hasRequiredPermissions(),
    androidSdk: Build.VERSION.SDK_INT,
    targetSdk: appTargetSdkVersion(),
    permissionMode: permissionModeOf(hasModernBluetoothPermissions())
  }
  pushDiagnostic('bluetooth_state', state)
  return Promise.resolve(state)
}

export function listKnownDevices(): Promise<Array<any>> {
  const initError = ensureInitialized()
  if (initError != null) {
    return rejectWith<Array<any>>(initError)
  }
  const devices = bondedOleapDevices()
  pushDiagnostic('known_devices', {
    count: devices.length,
    devices: devices.map((device: OleapDeviceInfo) => ({
      deviceId: device.deviceId,
      name: device.name
    }))
  })
  return Promise.resolve(devices.map((device: OleapDeviceInfo) => ({
    deviceId: device.deviceId,
    name: device.name,
    rssi: device.rssi,
    manufacturerDataHex: device.manufacturerDataHex,
    source: 'bonded'
  })))
}

export function startScan(options: any | null = null): Promise<void> {
  const initError = ensureInitialized()
  if (initError != null) {
    return rejectWith<void>(initError)
  }
  if (!hasRequiredPermissions()) {
    return rejectWith<void>(
      makeError('permission_denied', '请先授予蓝牙扫描权限', 'permission', true)
    )
  }
  const adapter = getBluetoothAdapter()
  if (adapter == null) {
    return rejectWith<void>(
      makeError('bluetooth_unsupported', '当前设备不支持蓝牙', 'bluetooth', false)
    )
  }
  if (!adapter.isEnabled()) {
    return rejectWith<void>(
      makeError('bluetooth_off', '系统蓝牙未开启', 'bluetooth', true)
    )
  }
  const scanner = adapter.getBluetoothLeScanner()
  if (scanner == null) {
    return rejectWith<void>(
      makeError('scanner_unavailable', '无法获取 BLE 扫描器', 'bluetooth', true)
    )
  }

  stopScanInternal(false)
  discoveredDeviceIds.clear()
  const callback = new OleapScanCallback()
  const timeoutMs = optionPositiveNumber(options, 'timeoutMs', DEFAULT_SCAN_TIMEOUT_MS)
  scannerCallback = callback
  try {
    scanner.startScan(callback)
  } catch (error) {
    scannerCallback = null
    const bleError = `${error}`
    const fallbackStarted = startClassicDiscoveryFallback(adapter, bleError)
    if (fallbackStarted) {
      scanning = true
      scanTimeoutId = setTimeout(() => {
        stopScanInternal(true)
      }, timeoutMs)
      pushDiagnostic('scan_start_fallback', {
        timeoutMs,
        filter: OLEAP_NAME_PREFIX,
        bleError
      })
      return Promise.resolve()
    }
    const knownDeviceCount = emitKnownDevicesScanFallback(bleError)
    if (knownDeviceCount > 0) {
      scanning = false
      return Promise.resolve()
    }
    scanning = false
    return rejectWith<void>(
      makeError('scan_start_failed', '启动 Android BLE 扫描失败', 'bluetooth', true, {
        error: bleError,
        androidSdk: Build.VERSION.SDK_INT,
        targetSdk: appTargetSdkVersion(),
        permissionMode: permissionModeOf(hasModernBluetoothPermissions()),
        fallback: 'classic_discovery_unavailable',
        knownDeviceCount
      })
    )
  }
  scanning = true
  scanTimeoutId = setTimeout(() => {
    stopScanInternal(true)
  }, timeoutMs)
  pushDiagnostic('scan_start', {
    timeoutMs,
    filter: OLEAP_NAME_PREFIX
  })
  return Promise.resolve()
}

export function stopScan(): Promise<void> {
  const initError = ensureInitialized()
  if (initError != null) {
    return rejectWith<void>(initError)
  }
  stopScanInternal(true)
  return Promise.resolve()
}

export function connect(options: any): Promise<any> {
  const initError = ensureInitialized()
  if (initError != null) {
    return rejectWith<any>(initError)
  }
  if (!hasRequiredPermissions()) {
    return rejectWith<any>(
      makeError('permission_denied', '请先授予蓝牙连接权限', 'permission', true)
    )
  }
  if (connecting) {
    return rejectWith<any>(
      makeError('already_connecting', '已有连接流程正在进行', 'connection', true)
    )
  }
  const adapter = getBluetoothAdapter()
  if (adapter == null) {
    return rejectWith<any>(
      makeError('bluetooth_unsupported', '当前设备不支持蓝牙', 'bluetooth', false)
    )
  }
  if (!adapter.isEnabled()) {
    return rejectWith<any>(
      makeError('bluetooth_off', '系统蓝牙未开启', 'bluetooth', true)
    )
  }
  const deviceId = optionString(options, 'deviceId', null)
  if (deviceId == null || deviceId.length == 0) {
    return rejectWith<any>(
      makeError('device_id_required', 'connect 需要传入 deviceId', 'connection', false)
    )
  }
  const context = getContext()
  if (context == null) {
    return rejectWith<any>(
      makeError('context_missing', '无法获取应用 Context', 'connection', true)
    )
  }

  stopScanInternal(false)
  closeGatt(false)
  clearCharacteristicCache()
  const generationAtStart = sessionGeneration
  connecting = true
  pendingDeviceId = deviceId
  pendingDeviceName = optionString(options, 'name', null)

  return new Promise<any>((resolve, reject) => {
    pendingConnectResolve = resolve
    pendingConnectReject = reject
    const requestedTimeoutMs = optionInt(options, 'timeoutMs', DEFAULT_CONNECT_TIMEOUT_MS)
    const timeoutMs: Int = requestedTimeoutMs > 0 ? requestedTimeoutMs : DEFAULT_CONNECT_TIMEOUT_MS
    connectTimeoutId = setTimeout(() => {
      const error = makeError(
        'connect_timeout',
        'Android GATT 连接超时',
        'connection',
        true,
        {
          deviceId: connectedDeviceId,
          pendingDeviceId,
          timeoutMs,
          generation: generationAtStart
        }
      )
      closeGatt(true)
      rejectPendingConnect(error)
    }, timeoutMs)

    try {
      const remoteDevice = adapter.getRemoteDevice(deviceId)
      const callback = new OleapGattCallback(generationAtStart)
      gattCallback = callback
      connectedGatt = remoteDevice.connectGatt(context, false, callback, BluetoothDevice.TRANSPORT_LE)
      pushDiagnostic('connect_start', {
        deviceId,
        timeoutMs,
        generation: generationAtStart
      })
    } catch (error) {
      const connectError = makeError(
        'connect_start_failed',
        '启动 Android GATT 连接失败',
        'connection',
        true,
        { error: `${error}`, deviceId }
      )
      closeGatt(true)
      rejectPendingConnect(connectError)
    }
  })
}

export function disconnect(): Promise<void> {
  stopScanInternal(true)
  closeGatt(true)
  emitConnectionChanged(false, null)
  return Promise.resolve()
}

export function getConnectionState(): any {
  return {
    connected: connectedDeviceId != null,
    connecting,
    device: connectedDeviceId == null
      ? null
      : {
          deviceId: connectedDeviceId,
          name: connectedDeviceName ?? 'Oleap Device',
          rssi: 0,
          manufacturerDataHex: ''
        },
    generation: sessionGeneration,
    channels: channelReadySnapshot()
  }
}

export function getBattery(): Promise<number> {
  return queryDp(DP_ID_BATTERY).then((event: DpEvent | null): number => {
    return event == null ? 0 : (event.value as number)
  })
}

export function getSn(): Promise<string> {
  return queryDp(DP_ID_SN).then((event: DpEvent | null): string => {
    return event == null ? '' : `${event.value}`
  })
}

export function getDeviceName(): Promise<string> {
  return queryDp(DP_ID_DEVICE_NAME).then((event: DpEvent | null): string => {
    return event == null ? '' : `${event.value}`
  })
}

export function getFirmwareVersion(): Promise<string> {
  return queryDp(DP_ID_FIRMWARE_VERSION).then((event: DpEvent | null): string => {
    return event == null ? '' : `${event.value}`
  })
}

export function getHardwareVersion(): Promise<string> {
  return queryDp(DP_ID_HARDWARE_VERSION).then((event: DpEvent | null): string => {
    return event == null ? '' : `${event.value}`
  })
}

export function getEqMode(): Promise<any> {
  return queryDp(DP_ID_EQ_MODE).then((event: DpEvent | null): any => {
    return event == null ? {} : nonNullAny(event.value)
  })
}

export function setEqMode(options: any): Promise<any> {
  const mode = optionInt(options, 'mode', -1)
  if (mode < 0 || mode > 255) {
    return rejectWith<any>(
      makeError('invalid_eq_mode', 'EQ 模式必须是 0-255 的整数', 'control', false, { mode })
    )
  }
  return writeDp(DP_ID_EQ_MODE, DP_TYPE_RAW, [mode]).then((event: DpEvent | null): any => {
    if (event == null) {
      return {
        modeCount: 0,
        currentMode: mode,
        raw: [mode]
      }
    }
    return nonNullAny(event.value)
  })
}

export function getRecordState(): Promise<any> {
  return queryDp(DP_ID_RECORD_STATE).then((event: DpEvent | null): any => {
    return event == null ? {} : nonNullAny(event.value)
  })
}

export function getFlashCapacity(): Promise<any> {
  return queryDp(DP_ID_FLASH_CAPACITY).then((event: DpEvent | null): any => {
    return event == null ? {} : nonNullAny(event.value)
  })
}

export function syncAppTime(): Promise<void> {
  const now = new Date()
  return writeDp(DP_ID_APP_TIME, DP_TYPE_RAW, [
    now.getFullYear() % 100,
    now.getMonth() + 1,
    now.getDate(),
    now.getHours(),
    now.getMinutes(),
    now.getSeconds()
  ]).then((_event) => {})
}

export function startRecording(options: any | null = null): Promise<any> {
  const readyError = ensureRecordingReady()
  if (readyError != null) {
    return rejectWith<any>(readyError)
  }
  const activeSession = recordingSession
  if (activeSession != null) {
    return rejectWith<any>(
      makeError('recording_already_active', '已有实时录音正在进行', 'recording', true, {
        sessionId: activeSession.sessionId
      })
    )
  }
  const pendingCommand = pendingRecordingCommand
  if (pendingCommand != null) {
    return rejectWith<any>(
      makeError('recording_command_pending', '已有录音协议命令正在等待响应', 'recording', true, {
        kind: pendingCommand.kind
      })
    )
  }

  let scene: RecordingSceneCommand
  try {
    scene = recordingSceneCommandOf(optionValue(options, 'scene'))
  } catch (error) {
    const maybeError = asNativeError(error)
    if (maybeError != null) {
      return rejectWith<any>(maybeError)
    }
    return rejectWith<any>(
      makeError('invalid_recording_scene', '录音场景不支持', 'recording', false, { error: `${error}` })
    )
  }

  return new Promise<any>((resolve, reject) => {
    const command = buildRecordingCommand(scene.command, [0])
    const request = new RecordingCommandRequest('start', command, sessionGeneration, resolve, reject)
    request.scene = scene.scene
    request.options = options
    pendingRecordingCommand = request
    startRecordingCommandTimeout(request)
    pushDiagnostic('recording_start_enqueued', {
      scene: scene.scene,
      command: scene.command,
      generation: sessionGeneration,
      enableRealtimeStream: optionBoolean(options, 'enableRealtimeStream', false)
    })
    writeRecordBytes(command, false)
      .then(() => {
        pushDiagnostic('recording_start_written', {
          scene: scene.scene,
          length: command.length,
          generation: sessionGeneration
        })
      })
      .catch((error) => {
        rejectRecordingCommand(
          request,
          makeError('recording_write_failed', '录音启动命令写入失败', 'recording', true, {
            kind: 'start',
            scene: scene.scene,
            error: `${error}`
          })
        )
      })
  })
}

export function stopRecording(options: any | null = null): Promise<any> {
  const readyError = ensureRecordingReady()
  if (readyError != null) {
    return rejectWith<any>(readyError)
  }
  const activeSession = recordingSession
  if (activeSession == null) {
    return rejectWith<any>(
      makeError('recording_not_active', '当前没有正在进行的实时录音', 'recording', true)
    )
  }
  const pendingCommand = pendingRecordingCommand
  if (pendingCommand != null) {
    return rejectWith<any>(
      makeError('recording_command_pending', '已有录音协议命令正在等待响应', 'recording', true, {
        kind: pendingCommand.kind
      })
    )
  }

  let format = 'wav'
  try {
    format = requestedRecordingFormatOf(options)
  } catch (error) {
    const maybeError = asNativeError(error)
    if (maybeError != null) {
      return rejectWith<any>(maybeError)
    }
    return rejectWith<any>(
      makeError('invalid_recording_format', '录音输出格式仅支持 wav 或 mp3', 'recording', false, { error: `${error}` })
    )
  }

  return new Promise<any>((resolve, reject) => {
    const command = buildRecordingCommand(RECORDING_COMMAND_STOP, [1])
    const request = new RecordingCommandRequest('stop', command, sessionGeneration, resolve, reject)
    request.format = format
    pendingRecordingCommand = request
    startRecordingCommandTimeout(request)
    pushDiagnostic('recording_stop_enqueued', {
      sessionId: activeSession.sessionId,
      requestedFormat: format,
      generation: sessionGeneration
    })
    writeRecordBytes(command, false)
      .then(() => {
        pushDiagnostic('recording_stop_written', {
          length: command.length,
          generation: sessionGeneration
        })
      })
      .catch((error) => {
        rejectRecordingCommand(
          request,
          makeError('recording_write_failed', '录音停止命令写入失败', 'recording', true, {
            kind: 'stop',
            sessionId: activeSession.sessionId,
            error: `${error}`
          })
        )
      })
  })
}

export function listFlashRecordings(): Promise<Array<any>> {
  return queryFlashFileCount().then((countResponse: RecordingResponse): Promise<Array<any>> => {
    if (countResponse.empty == true) {
      flashHeadFileId = null
      flashFileListSnapshot.splice(0, flashFileListSnapshot.length)
      return Promise.resolve(new Array<any>())
    }
    flashHeadFileId = countResponse.fileStartId
    const count = Math.min(countResponse.fileCount, 64).toInt()
    const fileIds = new Array<number>()
    for (let index: Int = 0; index < count; index++) {
      fileIds.push(normalizeUint32(countResponse.fileStartId + index))
    }
    return new Promise<Array<any>>((resolve, reject) => {
      const results = new Array<any>()
      loadFlashFileInfos(fileIds, 0, results, resolve, reject)
    })
  })
}

export function downloadFlashRecording(options: any): Promise<any> {
  const readyError = ensureFlashReady()
  if (readyError != null) {
    return rejectWith<any>(readyError)
  }
  const pendingCommand = pendingFlashCommand
  if (pendingCommand != null) {
    return rejectWith<any>(
      makeError('flash_command_pending', '已有 Flash 协议命令正在等待响应', 'flash', true, {
        kind: pendingCommand.kind
      })
    )
  }

  let format = 'wav'
  try {
    format = requestedRecordingFormatOf(options)
  } catch (error) {
    const maybeError = asNativeError(error)
    if (maybeError != null) {
      return rejectWith<any>(maybeError)
    }
    return rejectWith<any>(
      makeError('invalid_recording_format', '录音输出格式仅支持 wav 或 mp3', 'flash', false, { error: `${error}` })
    )
  }

  const requestedFileId = optionValue(options, 'fileId')
  const deleteAfterSuccess = optionBoolean(options, 'deleteAfterSuccess', false)
  if (requestedFileId == null) {
    return listFlashRecordings().then((files: Array<any>): Promise<any> => {
      if (files.length == 0) {
        return rejectWith<any>(
          makeError('flash_file_missing', '没有可下载的 Flash 文件', 'flash', true)
        )
      }
      const firstItem = files[0]
      if (firstItem == null) {
        return rejectWith<any>(
          makeError('flash_file_id_missing', 'Flash 文件列表缺少 fileId', 'flash', true)
        )
      }
      const first = new UTSJSONObject(firstItem)
      const firstFileId = first.getNumber('fileId')
      if (firstFileId == null || firstFileId < 0) {
        return rejectWith<any>(
          makeError('flash_file_id_missing', 'Flash 文件列表缺少 fileId', 'flash', true)
        )
      }
      return downloadFlashRecording({
        fileId: firstFileId,
        format,
        deleteAfterSuccess
      })
    })
  }

  const fileId = optionInt(options, 'fileId', -1)
  if (isNaN(fileId) || fileId < 0) {
    return rejectWith<any>(
      makeError('invalid_flash_file_id', 'Flash fileId 必须是非负整数', 'flash', false, {
        fileId: requestedFileId
      })
    )
  }

  return validateFlashDeleteOrder(fileId, deleteAfterSuccess)
    .then((_countResponse: RecordingResponse): Promise<RecordingResponse> => queryFlashFileInfo(fileId))
    .then((infoResponse: RecordingResponse): Promise<any> => {
      if (infoResponse.isFileExist != true || infoResponse.fileInfo == null) {
        return rejectWith<any>(
          makeError('flash_file_missing', 'Flash 文件不存在', 'flash', true, { fileId })
        )
      }
      return new Promise<any>((resolve, reject) => {
        const fileInfo = infoResponse.fileInfo!
        const session = createFlashRecordingSession(fileInfo)
        const active = new FlashDownloadSession(fileInfo, format, deleteAfterSuccess, session, resolve, reject)
        flashSession = active
        emitRecordingProgress(session, true)
        const command = buildFlashDownloadCommand(fileId, 0, true)
        pushDiagnostic('flash_download_start', {
          fileId,
          fileLength: fileInfo.fileLength,
          format,
          deleteAfterSuccess
        })
        writeRecordBytes(command, false)
          .then(() => {
            startFlashDownloadTimeout(active)
            pushDiagnostic('flash_download_written', {
              fileId,
              length: command.length
            })
          })
          .catch((error) => {
            rejectFlashSession(
              active,
              makeError('flash_write_failed', 'Flash 下载命令写入失败', 'flash', true, {
                fileId,
                error: `${error}`
              })
            )
          })
      })
    })
}

export function stopFlashDownload(): Promise<void> {
  const active = flashSession
  if (active == null) {
    return Promise.resolve()
  }
  rejectFlashSession(
    active,
    makeError('flash_download_interrupted', 'Flash 下载已停止', 'flash', true, {
      fileId: active.fileInfo.fileId,
      downloadedBytes: active.session.downloadedBytes
    }),
    false
  )
  return writeRecordBytes(buildFlashStopUploadCommand(), true)
    .then(() => {
      pushDiagnostic('flash_download_stop_written', {
        fileId: active.fileInfo.fileId
      })
    })
    .catch((error) => {
      emitError(makeError('flash_stop_failed', '停止 Flash 下载命令写入失败', 'flash', true, {
        error: `${error}`
      }))
    })
}

@UTSJS.keepAlive
export function onDeviceFound(callback: NativeDeviceFoundCallback): () => void {
  deviceFoundCallbacks.add(callback)
  return () => {
    deviceFoundCallbacks.delete(callback)
  }
}

@UTSJS.keepAlive
export function onConnectionChanged(callback: NativeConnectionCallback): () => void {
  connectionCallbacks.add(callback)
  return () => {
    connectionCallbacks.delete(callback)
  }
}

