class OleapDeviceInfo {
  deviceId: string
  name: string
  rssi: number
  manufacturerDataHex: string

  constructor(deviceId: string, name: string, rssi: number, manufacturerDataHex: string = '') {
    this.deviceId = deviceId
    this.name = name
    this.rssi = rssi
    this.manufacturerDataHex = manufacturerDataHex
  }
}

class WriteRequest {
  channel: string
  value: Array<number>
  withoutResponse: boolean
  generation: number
  resolve: () => void
  reject: (error: any | null) => void
  gatt: BluetoothGatt | null = null
  characteristicUuid: string = ''

  constructor(
    channel: string,
    value: Array<number>,
    withoutResponse: boolean,
    generation: number,
    resolve: () => void,
    reject: (error: any | null) => void
  ) {
    this.channel = channel
    this.value = value
    this.withoutResponse = withoutResponse
    this.generation = generation
    this.resolve = resolve
    this.reject = reject
  }
}

