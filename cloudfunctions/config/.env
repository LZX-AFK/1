# cloudfunctions/config/.env（不进 Git）
# B 需要填写的 API Key

# === 百度智能云（菜品识别） ===
# 获取地址: https://console.bce.baidu.com/ai/#/ai/imagerecognition/overview/index
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here

# === 豆包 / 火山方舟（生图 + 文本） ===
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint
DOUBAO_API_KEY=your_doubao_api_key_here

# === 豆包模型（可选覆盖，不填则用默认） ===
# DOUBAO_IMG_MODEL=doubao-seedream-3-0-t2i-250415
# DOUBAO_TEXT_MODEL=doubao-pro-32k-250115

# === 微信云开发 ===
# CLOUD_ENV_ID=your_cloud_env_id_here
