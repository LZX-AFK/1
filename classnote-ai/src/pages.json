{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/home/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/courses/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "我的课程"
      }
    },
    {
      "path": "pages/record/prepare",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "课堂录音"
      }
    },
    {
      "path": "pages/knowledge/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "知识库"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "我的"
      }
    },
    {
      "path": "pages/courses/detail",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "课程详情"
      }
    },
    {
      "path": "pages/record/live",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "实时转写"
      }
    },
    {
      "path": "pages/record/summary",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "AI 总结"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "ClassNote AI",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F3F4F6"
  },
  "tabBar": {
    "color": "#9CA3AF",
    "selectedColor": "#4F46E5",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/index",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/courses/index",
        "iconPath": "static/tabbar/courses.png",
        "selectedIconPath": "static/tabbar/courses-active.png",
        "text": "课程"
      },
      {
        "pagePath": "pages/record/prepare",
        "iconPath": "static/tabbar/record.png",
        "selectedIconPath": "static/tabbar/record-active.png",
        "text": "录音"
      },
      {
        "pagePath": "pages/knowledge/index",
        "iconPath": "static/tabbar/knowledge.png",
        "selectedIconPath": "static/tabbar/knowledge-active.png",
        "text": "知识库"
      },
      {
        "pagePath": "pages/profile/index",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png",
        "text": "我的"
      }
    ]
  }
}
