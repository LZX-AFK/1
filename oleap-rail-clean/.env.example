PORT=3000

# ---- 数据库 ----
DATABASE_URL="file:./dev.db"

# ---- ASR Provider ----
# 可选: doubao | dashscope
ASR_PROVIDER=doubao

# ---- 豆包/火山引擎 ASR ----
DOUBAO_ASR_API_KEY=
DOUBAO_ASR_APP_ID=
DOUBAO_ASR_CLUSTER=volc.bigasr.sauc
DOUBAO_ASR_WS_URL=wss://openspeech.bytedance.com/api/v2/asr
DOUBAO_ASR_SAMPLE_RATE=16000
DOUBAO_ASR_TIMEOUT_MS=30000

# ---- DashScope ASR（阿里云）----
DASHSCOPE_API_KEY=

# ---- AI Provider ----
# 可选: deepseek | external
AI_SERVICE_PROVIDER=deepseek

# ---- DeepSeek LLM ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=30000

# ---- 外部 AI Service（兼容旧方案）----
AI_SERVICE_URL=
