# 数据库
DATABASE_URL="file:./dev.db"

# Deepgram（已弃用，备用）
DEEPGRAM_API_KEY="your_deepgram_api_key"

# 阿里云百炼 DashScope（当前使用的 ASR 服务）
DASHSCOPE_API_KEY="sk-your_dashscope_api_key"

# Cloudflare R2（可选，未配置则自动降级为本地存储）
R2_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
R2_BUCKET="classnote-audio"
R2_ACCESS_KEY="your_r2_access_key"
R2_SECRET_KEY="your_r2_secret_key"

# AI 总结服务（可选，未配置则使用 Mock 本地生成）
AI_SERVICE_URL="http://localhost:3001/generate-summary"

# 服务端口
PORT=3000

# 临时文件目录
TEMP_DIR="./temp"
